---
---

<section id="yearbook" class="py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <div
      class="relative overflow-hidden rounded-3xl bg-dark px-8 py-16 md:px-16 md:py-20 text-center"
    >
      <!-- Ambient glows inside the dark strip -->
      <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <div class="absolute -top-24 -left-24 w-64 h-64 rounded-full bg-primary/20 blur-[80px]"></div>
        <div class="absolute -bottom-24 -right-24 w-72 h-72 rounded-full bg-mint/10 blur-[80px]"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-48 rounded-full bg-periwinkle/8 blur-[60px]"></div>
      </div>

      <!-- Decorative top rule -->
      <div class="absolute top-0 left-1/4 right-1/4 h-px bg-gradient-to-r from-transparent via-primary/50 to-transparent"></div>

      <!-- Content -->
      <div class="relative z-10 max-w-xl mx-auto space-y-6">
        <!-- Badge -->
        <span class="inline-flex items-center gap-2 text-xs font-medium px-3 py-1.5 rounded-full bg-primary/20 text-periwinkle border border-primary/20">
          <span class="w-1.5 h-1.5 rounded-full bg-mint animate-pulse"></span>
          Newsletter · Free forever
        </span>

        <!-- Heading -->
        <h2 class="font-display text-[clamp(2rem,4vw,3rem)] text-off-white leading-tight">
          The Yearbook
        </h2>

        <!-- Subtext -->
        <p class="text-[1rem] font-light leading-relaxed text-off-white/85 max-w-sm mx-auto">
          Life lessons, personal updates, and YouTube BTS...<br class="hidden sm:block"/>
          written for my kids to find someday.
        </p>

        <!-- Email form -->
        <form
          id="yearbook-form"
          class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto pt-2"
          novalidate
        >
          <input
            type="email"
            name="email_address"
            placeholder="your@email.com"
            required
            autocomplete="email"
            class="flex-1 px-5 py-3.5 rounded-full bg-off-white/8 border border-off-white/15 text-off-white placeholder:text-off-white/35 text-sm font-light focus:outline-none focus:border-primary/60 focus:bg-off-white/12 transition-all"
          />
          <button
            type="submit"
            class="px-6 py-3.5 rounded-full font-medium text-sm text-dark whitespace-nowrap
              bg-mint hover:bg-mint/90 hover:shadow-lg hover:shadow-mint/25 hover:-translate-y-0.5
              transition-all duration-200 active:scale-95"
            style="color: #1A1523;"
          >
            Subscribble Fo Shizzle
          </button>
        </form>

        <div
          id="yearbook-success"
          class="hidden py-3 px-5 rounded-xl bg-mint/15 border border-mint/25 text-sm font-medium text-off-white"
        >
          You're in! Check your inbox. ✨
        </div>

        <div
          id="yearbook-error"
          class="hidden py-3 px-5 rounded-xl bg-red-900/30 border border-red-400/25 text-sm font-medium text-red-300"
        >
          Something went wrong. Try again?
        </div>

        <!-- Fine print -->
        <p class="text-[11px] text-off-white/55 font-light">
          No spam. No algorithm. Just writing. Unsubscribe whenever.
        </p>
      </div>

      <!-- Decorative bottom rule -->
      <div class="absolute bottom-0 left-1/4 right-1/4 h-px bg-gradient-to-r from-transparent via-mint/20 to-transparent"></div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('yearbook-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('yearbook-success');
  const errorMsg = document.getElementById('yearbook-error');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const emailInput = form.querySelector<HTMLInputElement>('input[name="email_address"]');
      const email = emailInput ? emailInput.value.trim() : '';
      if (!email) return;

      const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Subscribing…';
      }

      if (errorMsg) errorMsg.classList.add('hidden');

      try {
        const res = await fetch(
          'https://app.kit.com/forms/9211740/subscriptions',
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email_address: email }),
          }
        );

        if (res.ok) {
          form.classList.add('hidden');
          if (successMsg) successMsg.classList.remove('hidden');
        } else {
          throw new Error(`Status ${res.status}`);
        }
      } catch (err) {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Subscribble Fo Shizzle';
        }
        if (errorMsg) errorMsg.classList.remove('hidden');
      }
    });
  }
</script>
