---
const stats = [
  { value: '101M+', label: 'Views Generated', emoji: '👀' },
  { value: '12+',   label: 'Years Creating',  emoji: '📅' },
  { value: '36K',   label: 'Subscribers',     emoji: '🎬' },
];
---

<div class="relative mt-16 mb-2">
  <div class="w-px h-10 bg-gradient-to-b from-transparent to-primary/20 mx-auto"></div>

  <div class="max-w-6xl mx-auto px-6">
    <div id="stats-bar" class="grid grid-cols-3 gap-4 md:gap-8 py-6">
      {stats.map((stat, i) => (
        <div
          class="stat-float flex flex-col items-center text-center"
          data-index={i}
        >
          <span class="text-2xl mb-3 select-none">{stat.emoji}</span>
          <span
            class="stat-number font-display text-[clamp(2.4rem,5vw,3.8rem)] leading-none text-dark tabular-nums"
            data-value={stat.value}
          >
            {stat.value}
          </span>
          <span class="mt-2 text-[11px] font-medium uppercase tracking-widest text-dark/45">
            {stat.label}
          </span>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  @keyframes float-0 {
    0%, 100% { transform: translateY(0px);  }
    50%       { transform: translateY(-10px); }
  }
  @keyframes float-1 {
    0%, 100% { transform: translateY(0px);  }
    50%       { transform: translateY(-14px); }
  }
  @keyframes float-2 {
    0%, 100% { transform: translateY(0px);  }
    50%       { transform: translateY(-8px);  }
  }

  .stat-float[data-index="0"] { animation: float-0 6s ease-in-out infinite; }
  .stat-float[data-index="1"] { animation: float-1 7.5s ease-in-out infinite 1s; }
  .stat-float[data-index="2"] { animation: float-2 5.5s ease-in-out infinite 0.5s; }
</style>

<script>
  function animateNumber(el: Element, target: string) {
    const hasPlus = target.includes('+');
    const hasK    = target.includes('K');
    const hasM    = target.includes('M');
    const raw     = parseFloat(target.replace(/[^0-9.]/g, ''));
    const dur     = 7000;
    const start   = performance.now();

    const fmt = (n: number): string => {
      const r = Math.round(n);
      if (hasM) return r + 'M' + (hasPlus ? '+' : '');
      if (hasK) return r + 'K' + (hasPlus ? '+' : '');
      return String(r) + (hasPlus ? '+' : '');
    };

    const tick = (now: number) => {
      const elapsed  = now - start;
      const progress = Math.min(elapsed / dur, 1);
      const eased    = 1 - Math.pow(1 - progress, 3);
      el.textContent = fmt(eased * raw);
      if (progress < 1) requestAnimationFrame(tick);
    };

    el.textContent = fmt(0);
    requestAnimationFrame(tick);
  }

  const bar = document.getElementById('stats-bar');
  if (bar) {
    const observer = new IntersectionObserver(
      entries => {
        if (entries[0].isIntersecting) {
          bar.querySelectorAll<HTMLElement>('.stat-number').forEach(el => {
            const val = el.dataset.value;
            if (val) animateNumber(el, val);
          });
          observer.disconnect();
        }
      },
      { threshold: 0.4 }
    );
    observer.observe(bar);
  }
</script>
