  {
    name: 'YouTube',
    href: 'https://www.youtube.com/@dinofavarajr',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M23.5 6.19a3.02 3.02 0 00-2.12-2.14C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.38.55A3.02 3.02 0 00.5 6.19C0 8.09 0 12 0 12s0 3.91.5 5.81a3.02 3.02 0 002.12 2.14C4.5 20.5 12 20.5 12 20.5s7.5 0 9.38-.55a3.02 3.02 0 002.12-2.14C24 15.91 24 12 24 12s0-3.91-.5-5.81zM9.75 15.5V8.5l6.5 3.5-6.5 3.5z"/></svg>`,
  },
  {
    name: 'Instagram',
    href: 'https://www.instagram.com/dinofavara/',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>`,
  },
  {
    name: 'TikTok',
    href: 'https://www.tiktok.com/@notdinofavara',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1.01-.06z"/></svg>`,
  },
  {
    name: 'X / Twitter',
    href: 'https://x.com/dinofavara',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
];

const footerLinks = [
  { label: 'About',        href: '/about'    },
  { label: 'Work',         href: '/work'     },
  { label: 'Writing',      href: '/writing'  },
  { label: 'Now',          href: '/now'      },
  { label: 'The Yearbook', href: '/yearbook' },
  { label: 'Disney',       href: '/disney', comingSoon: true },
];
---

<footer class="border-t border-dark/8 bg-off-white">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-8">

      <!-- Logo + tagline -->
      <div class="space-y-2">
        <a href="/" class="flex items-center gap-2.5 group w-fit">
          <span class="text-2xl select-none">🦕</span>
          <span class="font-display text-[1.1rem] tracking-tight text-dark group-hover:text-primary transition-colors">
            Dino Favara Jr.
          </span>
        </a>
        <p class="text-xs font-light text-dark/45 pl-[2.6rem]">
          Making stories that feel like something.
        </p>
      </div>

      <!-- Nav links -->
      <nav class="flex flex-wrap gap-x-6 gap-y-2" aria-label="Footer navigation">
        {footerLinks.map(link => (
          <a
            href={link.href}
            class="inline-flex items-center gap-1.5 text-sm text-dark/55 hover:text-primary transition-colors duration-200"
          >
            {link.label}
            {link.comingSoon && (
              <span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full bg-dark/8 text-dark/40 leading-none">
                soon
              </span>
            )}
          </a>
        ))}
      </nav>

      <!-- Socials -->
      <div class="flex items-center gap-3">
        {socials.map(s => (
          <a
            href={s.href}
            aria-label={s.name}
            class="w-9 h-9 rounded-full border border-dark/12 flex items-center justify-center text-dark/45 hover:text-primary hover:border-primary/30 hover:bg-primary/6 transition-all duration-200"
            set:html={s.icon}
          />
        ))}
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-6 border-t border-dark/6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-dark/35">
      <p>© {new Date().getFullYear()} Dino Favara Jr. All rights reserved.</p>
      <p class="flex items-center gap-1.5">
        Built with
        <a href="https://astro.build" class="hover:text-primary transition-colors underline underline-offset-2">Astro</a>
        &
        <a href="https://tailwindcss.com" class="hover:text-primary transition-colors underline underline-offset-2">Tailwind</a>
        · Deployed on
        <a href="https://vercel.com" class="hover:text-primary transition-colors underline underline-offset-2">Vercel</a>
      </p>
    </div>
  </div>
</footer>
