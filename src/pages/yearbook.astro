---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="The Yearbook | Dino Favara Jr."
  description="Every month I document what it looks like to build a YouTube channel while holding down a full-time job, raising a family, and without sacrificing my health."
>
  <Nav />

  <main style="background:#F2F0EB;">
    <section class="max-w-xl mx-auto px-6 py-24 flex flex-col items-center text-center gap-6">

      <!-- Pill tag -->
      <span
        class="inline-block px-4 py-1.5 rounded-full text-[0.65rem] font-medium tracking-[0.14em] uppercase"
        style="background:#3BFFB3; color:#0a3326;"
      >
        Free · Monthly
      </span>

      <!-- Headline -->
      <h1 class="font-body font-light text-[clamp(2.8rem,6vw,4.5rem)] leading-[1.06] tracking-tight text-dark">
        The <span class="font-display italic text-primary">Yearbook</span>
      </h1>

      <!-- Subheading -->
      <p class="text-base font-light italic" style="color:#9a9890;">
        AI-Free. Written by a Human. Always.
      </p>

      <!-- Divider -->
      <div class="w-10 h-px bg-primary"></div>

      <!-- Body copy -->
      <p class="text-[1.05rem] font-light leading-relaxed" style="color:#4a4850; max-width:34rem;">
        Every month I document what it looks like to build a YouTube channel while holding down a full-time job, raising a family, and without sacrificing my health. I share real updates, behind the scenes planning, and actionable steps to show what it takes to get paid for making things in 2026 and beyond.
      </p>

      <!-- Signup form -->
      <div id="yearbook-form-wrapper" class="w-full max-w-md mt-2">
        <form
          id="yearbook-signup"
          class="flex overflow-hidden rounded-full border"
          style="background:#ffffff; border-color:#dedad4;"
          novalidate
        >
          <input
            type="email"
            name="email_address"
            placeholder="your@email.com"
            required
            autocomplete="email"
            class="flex-1 min-w-0 px-5 py-3 text-sm bg-transparent outline-none"
            style="color:#1A1523;"
          />
          <button
            type="submit"
            class="px-6 py-3 text-sm font-medium text-off-white whitespace-nowrap bg-primary hover:bg-primary/90 transition-colors active:scale-95"
          >
            Get The Yearbook
          </button>
        </form>

        <div
          id="yearbook-success"
          class="hidden mt-3 py-3 px-5 rounded-xl text-sm font-medium text-dark"
          style="background:rgba(59,255,179,0.15); border:1px solid rgba(59,255,179,0.3);"
        >
          You're in! Check your inbox.
        </div>
        <div
          id="yearbook-error"
          class="hidden mt-3 py-3 px-5 rounded-xl text-sm font-medium text-red-700 bg-red-50 border border-red-200"
        >
          Something went wrong. Try again?
        </div>

        <p class="mt-3 text-xs" style="color:#9a9890;">
          One email a month. Unsubscribe whenever.
        </p>
      </div>

    </section>

    <!-- Season note -->
    <p
      class="text-center pb-12 text-[0.65rem] font-medium tracking-[0.14em] uppercase"
      style="color:#9a9890;"
    >
      Season 4 - 2026
    </p>
  </main>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('yearbook-signup') as HTMLFormElement | null;
  const successMsg = document.getElementById('yearbook-success');
  const errorMsg   = document.getElementById('yearbook-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const emailInput = form.querySelector('input[name="email_address"]') as HTMLInputElement | null;
    const email = emailInput?.value.trim() ?? '';
    if (!email) return;

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (btn) { btn.disabled = true; btn.textContent = 'Subscribing…'; }
    errorMsg?.classList.add('hidden');

    try {
      const res = await fetch('https://app.kit.com/forms/9211740/subscriptions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email_address: email }),
      });

      if (res.ok) {
        form.classList.add('hidden');
        successMsg?.classList.remove('hidden');
      } else {
        throw new Error(`HTTP ${res.status}`);
      }
    } catch {
      if (btn) { btn.disabled = false; btn.textContent = 'Get The Yearbook'; }
      errorMsg?.classList.remove('hidden');
    }
  });
</script>
