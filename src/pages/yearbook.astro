---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import KitForm from '../components/KitForm.astro';

interface Post {
  title: string;
  link: string;
  pubDate: string;
  description: string;
}

let posts: Post[] = [];

try {
  const res = await fetch('https://dinofavarajr.kit.com/posts.rss', {
    headers: { 'User-Agent': 'Mozilla/5.0 (compatible; Astro/RSS-parser)' },
  });

  if (res.ok) {
    const xml = await res.text();
    const itemMatches = xml.matchAll(/<item>([\s\S]*?)<\/item>/g);

    for (const match of itemMatches) {
      if (posts.length >= 10) break;
      const item = match[1];

      const extract = (tag: string, src: string): string => {
        const re = new RegExp(`<${tag}[^>]*>(?:<!\\[CDATA\\[([\\s\\S]*?)\\]\\]>|([^<]*))</${tag}>`, 'i');
        const m = src.match(re);
        if (!m) return '';
        return (m[1] ?? m[2] ?? '').trim();
      };

      const rawTitle = extract('title', item);
      const rawLink  = extract('link', item) || (() => {
        const m = item.match(/<link>(.*?)<\/link>/i);
        return m ? m[1].trim() : '';
      })();
      const rawDate  = extract('pubDate', item);
      const rawDesc  = extract('description', item) || extract('content:encoded', item);

      const stripped = rawDesc
        .replace(/<[^>]+>/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
      const excerpt = stripped.length > 160
        ? stripped.slice(0, 157) + '…'
        : stripped;

      let pubDate = '';
      try {
        pubDate = new Date(rawDate).toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        });
      } catch {
        pubDate = rawDate;
      }

      posts.push({ title: rawTitle, link: rawLink, pubDate, description: excerpt });
    }
  }
} catch {
  posts = [];
}
---

<Layout
  title="The Yearbook — Dino Favara Jr."
  description="Lessons on life, creativity, and growing up — written for my kids to find someday. Subscribe to The Yearbook newsletter."
>
  <Nav />

  <main>
    <!-- ── Dark Hero ── -->
    <section class="relative overflow-hidden bg-dark py-24">
      <!-- Ambient blobs -->
      <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <div class="absolute -top-32 -left-32 w-[500px] h-[500px] rounded-full bg-primary/30 blur-[100px]"></div>
        <div class="absolute top-40 -right-20 w-[400px] h-[400px] rounded-full bg-periwinkle/20 blur-[90px]"></div>
        <div class="absolute bottom-0 left-1/3 w-[300px] h-[300px] rounded-full bg-mint/10 blur-[80px]"></div>
      </div>

      <div class="relative z-10 max-w-2xl mx-auto px-6 text-center flex flex-col items-center gap-6">
        <span class="text-6xl select-none" aria-hidden="true">📓</span>

        <h1 class="font-display text-[clamp(2.8rem,6vw,4.5rem)] leading-[1.06] tracking-tight text-off-white">
          The Yearbook
        </h1>
        <p class="text-[1.05rem] font-light text-off-white/60 leading-relaxed max-w-sm">
          Lessons on life, creativity, and growing up — written for my kids to find someday.
        </p>

        <div class="w-full max-w-md">
          <KitForm
            formId="9211740"
            instanceId="yearbook-hero-form"
            buttonStyle="mint"
            inputDark={true}
          />
        </div>

        <a
          href="https://theyearbook.beehiiv.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium text-periwinkle hover:text-mint transition-colors underline underline-offset-4"
        >
          Browse past issues →
        </a>
      </div>
    </section>

    <!-- ── Recent Issues ── -->
    <section class="py-20 max-w-6xl mx-auto px-6">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-px w-10 bg-primary/40 flex-shrink-0"></div>
        <span class="text-sm font-medium tracking-widest uppercase text-primary/70">Archive</span>
      </div>
      <h2 class="font-display text-3xl text-dark mb-10">Recent issues</h2>

      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map(post => (
            <a
              href={post.link}
              target="_blank"
              rel="noopener noreferrer"
              class="group rounded-2xl border border-dark/8 bg-white/50 p-6 flex flex-col gap-4 hover:border-primary/25 hover:shadow-md hover:shadow-primary/8 transition-all duration-300"
            >
              <h3 class="font-display text-lg text-dark leading-snug group-hover:text-primary transition-colors">
                {post.title}
              </h3>
              {post.description && (
                <p class="text-sm font-light text-dark/60 leading-relaxed flex-1">
                  {post.description}
                </p>
              )}
              <div class="flex items-center justify-between mt-auto pt-2 border-t border-dark/6">
                <time class="text-xs text-dark/40 font-medium">{post.pubDate}</time>
                <span class="text-xs font-medium text-primary group-hover:underline">Read →</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="rounded-2xl border border-dark/8 bg-white/40 p-14 text-center">
          <span class="text-5xl block mb-4">📓</span>
          <p class="font-display text-xl text-dark mb-2">Issues coming soon</p>
          <p class="text-sm font-light text-dark/50 max-w-xs mx-auto">
            Subscribe above to get the first ones delivered straight to your inbox.
          </p>
        </div>
      )}

      <div class="mt-12 text-center">
        <a
          href="https://theyearbook.beehiiv.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full border-2 border-primary text-primary font-medium text-sm hover:bg-primary hover:text-off-white transition-all duration-200"
        >
          Browse the full archive →
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
