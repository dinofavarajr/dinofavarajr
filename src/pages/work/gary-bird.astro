---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Gary Bird Case Study | Dino Favara Jr."
  description="From 533 YouTube subscribers and 1K average views to 47.1K subs and 50.5M total views in 86 days. Plus a 20M+ view mega outlier picked up by Yahoo Finance, New York Post, and more."
>
  <Nav />

  <main>
    <!-- Back link -->
    <section class="max-w-3xl mx-auto px-6 pt-10">
      <a href="/work" class="inline-flex items-center gap-2 text-sm font-medium text-primary/70 hover:text-primary transition-colors duration-200">
        &larr; All case studies
      </a>
    </section>

    <!-- Header -->
    <section class="max-w-3xl mx-auto px-6 pt-8 pb-12">
      <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-green-500/10 text-green-700 tracking-wide mb-6">
        Short-Form Growth
      </span>
      <h1 class="font-display text-[clamp(2rem,5vw,3.2rem)] leading-[1.1] tracking-tight text-dark mb-4">
        The Gary Bird
      </h1>
      <p class="text-lg font-light text-dark/60 leading-relaxed max-w-xl">
        From 533 YouTube subscribers and 1K average views to 47.1K subs and 50.5M total views in 86 days.
      </p>

      <!-- Service tags -->
      <div class="flex flex-wrap gap-2 mt-6">
        {['Content Strategy', 'Format Development', 'YouTube Shorts', 'TikTok Optimization', 'Instagram Reels', 'Cross-Platform Distribution'].map(tag => (
          <span class="px-3 py-1.5 rounded-full border border-dark/10 bg-white/60 text-xs font-medium text-dark/55">
            {tag}
          </span>
        ))}
      </div>
    </section>

    <!-- Before / After -->
    <section class="stats-section max-w-3xl mx-auto px-6 pb-12">
      <div class="rounded-2xl border border-dark/8 bg-white/70 overflow-hidden">
        <div class="grid grid-cols-1 md:grid-cols-[1fr_auto_1fr]">
          <!-- Before -->
          <div class="flex flex-col items-center justify-center py-10 px-8 text-center">
            <span class="text-[11px] font-medium uppercase tracking-widest text-dark/40 mb-3">Avg Views Before</span>
            <span class="count-up font-display text-[4.5rem] leading-none text-red-500" data-value="1000">1,000</span>
            <span class="mt-2 text-sm font-light text-dark/50">per video</span>
          </div>
          <!-- Arrow -->
          <div class="hidden md:flex items-center justify-center px-4">
            <span class="text-2xl text-dark/20">&rarr;</span>
          </div>
          <div class="flex md:hidden items-center justify-center py-2">
            <span class="text-2xl text-dark/20">&darr;</span>
          </div>
          <!-- After -->
          <div class="flex flex-col items-center justify-center py-10 px-8 text-center bg-green-500/4">
            <span class="text-[11px] font-medium uppercase tracking-widest text-dark/40 mb-3">Total Views After</span>
            <span class="count-up font-display text-[4.5rem] leading-none text-green-600" data-value="50.5M">50.5M</span>
            <span class="mt-2 text-sm font-light text-dark/50">in 86 days</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Metrics Grid -->
    <section class="stats-section max-w-3xl mx-auto px-6 pb-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { value: '47.1K', label: 'YouTube Subscribers', sub: '(from 533)' },
          { value: '+5K', label: 'TikTok Followers', sub: '(reversed stall)' },
          { value: '20M+', label: 'Mega Outlier Views', sub: '(across platforms)' },
          { value: '5', label: 'Major Media Pickups', sub: '(Yahoo, NYPost, more)' },
        ].map(m => (
          <div class="rounded-xl border border-dark/8 bg-white/60 p-5 text-center">
            <span class="count-up font-display text-3xl text-green-600" data-value={m.value}>{m.value}</span>
            <p class="mt-1 text-[11px] font-medium uppercase tracking-widest text-dark/45">{m.label}</p>
            <p class="mt-0.5 text-[10px] text-dark/35">{m.sub}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- SCREENSHOT SLOTS: Replace these with actual images -->
    <!-- Uncomment and replace src when you have screenshots ready
    <section class="max-w-3xl mx-auto px-6 pb-12">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="rounded-xl border border-dark/8 overflow-hidden">
          <img src="/images/case-studies/gary-bird-before.jpg" alt="Gary Bird YouTube before - 533 subscribers" class="w-full" />
        </div>
        <div class="rounded-xl border border-dark/8 overflow-hidden">
          <img src="/images/case-studies/gary-bird-after.jpg" alt="Gary Bird YouTube after - 47.1K subscribers" class="w-full" />
        </div>
      </div>
    </section>
    -->

    <!-- Body Content -->
    <section class="max-w-3xl mx-auto px-6 pb-16">
      <article class="prose-custom">
        <h3>The Situation</h3>
        <p>Gary Bird is an entrepreneur and founder of SMC National, a growth partner for dental practices. He's a 3x Inc. 5000 honoree with serious business credibility. But his content wasn't translating. By early 2023, he had 349 YouTube videos and only 533 subscribers. His TikTok had around 75K followers but viewership had stalled and he was slowly losing followers. Average views across platforms sat around 1,000 per video.</p>

        <h3>The Approach</h3>
        <p>Instead of telling Gary to post more, I did the opposite. We stripped the strategy back to fundamentals: <strong>what formats actually work in the business/entrepreneurship niche on short-form platforms?</strong></p>
        <p>I developed a repeatable format system built around Gary's natural strengths: his energy, his willingness to go on camera anywhere, and his genuine expertise in business growth. We focused on scroll-stopping hooks, tight editing rhythms, and topics that lived at the intersection of business advice and everyday relatability (grocery prices, time hacks, business mindset).</p>
        <p>On TikTok, the challenge wasn't starting from zero. It was reversing a stall. His follower count had been slowly declining, and his content wasn't reaching new audiences. We rebuilt his format library and content strategy to re-engage the algorithm and stabilize growth, ultimately gaining him 5K net new followers and reigniting his viewership.</p>
        <p>We also built a cross-platform distribution engine: each piece of content was optimized for TikTok, YouTube Shorts, and Instagram Reels simultaneously, with platform-specific tweaks rather than identical cross-posts.</p>

        <h3>The Results</h3>
        <p>In 86 days, Gary generated over 50.5 million total views across platforms. His YouTube went from 533 to 47,100 subscribers, an 8,740% increase. His TikTok stall reversed with 5K net new followers gained, and his Instagram grew to 9,716 followers. Individual videos regularly hit hundreds of thousands of views, with top performers reaching 3.5M and 4.9M views.</p>
        <p>One video in particular became a mega outlier, generating 20M+ views across all platforms. It didn't just go viral on social. It crossed over into mainstream media and was picked up by Yahoo Finance, the New York Post, The Independent, the Benny Johnson Show, and the Wall Street Bets Silver subreddit. That's the difference between a video that performs and a video that becomes a cultural moment.</p>
        <p>More importantly, the system was repeatable. Gary had a format library, a production rhythm, and a content thesis he could execute independently.</p>

        <!-- SCREENSHOT SLOT: Media pickups
        <div class="my-8 rounded-xl border border-dark/8 overflow-hidden">
          <img src="/images/case-studies/gary-bird-media.jpg" alt="Gary Bird video featured in Yahoo Finance, New York Post, The Independent" class="w-full" />
        </div>
        -->

        <!-- Testimonial -->
        <blockquote>
          <p>"Tried all sorts of video angles. Failed. After working with Mercury Media, we're at 100k+ on Tiktok and millions of views on our videos"</p>
          <cite>Gary Bird, Founder of SMC National</cite>
        </blockquote>
      </article>

      <!-- Timeline -->
      <div class="mt-12 pt-8 border-t border-dark/8">
        <span class="text-sm font-light text-dark/45">Timeline: 86 days</span>
        <div class="mt-2 h-1.5 w-full rounded-full bg-dark/6 overflow-hidden">
          <div class="h-full rounded-full bg-gradient-to-r from-primary to-mint" style="width: 100%"></div>
        </div>
      </div>
    </section>

    <!-- Back to Work CTA -->
    <section class="max-w-3xl mx-auto px-6 pb-20">
      <div class="rounded-2xl border border-dark/8 bg-white/60 p-8 flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <p class="font-display text-xl text-dark">Want results like this?</p>
          <p class="text-sm font-light text-dark/55 mt-1">Let's talk about building your content engine.</p>
        </div>
        <a
          href="mailto:dino@mercurysocialmedia.com"
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-primary text-off-white font-medium text-sm hover:bg-primary/90 hover:shadow-xl hover:shadow-primary/40 hover:-translate-y-0.5 transition-all duration-200 active:scale-95 whitespace-nowrap"
        >
          Email me &rarr;
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  function animateCount(el: HTMLElement) {
    const target = el.dataset.value ?? '';
    const hasPlus = target.includes('+');
    const hasM = target.includes('M');
    const hasK = target.includes('K');
    const hasPercent = target.includes('%');
    const hasX = /^\d+(\.\d+)?x$/.test(target.replace('+', ''));
    const clean = target.replace(/[+MKx%,\s]/gi, '').trim();
    if (!/^\d+\.?\d*$/.test(clean)) return;
    const raw = parseFloat(clean);
    if (isNaN(raw)) return;
    const dur = 1800;
    const start = performance.now();
    const fmt = (n: number): string => {
      if (hasM) return (Math.round(n * 10) / 10) + 'M' + (hasPlus ? '+' : '');
      if (hasK) return Math.round(n) + 'K' + (hasPlus ? '+' : '');
      if (hasPercent) return Math.round(n).toLocaleString() + '%';
      if (hasX) return Math.round(n) + 'x';
      return Math.round(n).toLocaleString() + (hasPlus ? '+' : '');
    };
    const tick = (now: number) => {
      const progress = Math.min((now - start) / dur, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = fmt(eased * raw);
      if (progress < 1) requestAnimationFrame(tick);
      else el.textContent = target;
    };
    el.textContent = fmt(0);
    requestAnimationFrame(tick);
  }

  const obs = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      entry.target.querySelectorAll<HTMLElement>('.count-up').forEach(animateCount);
      obs.unobserve(entry.target);
    });
  }, { threshold: 0.3 });

  document.querySelectorAll<HTMLElement>('.stats-section').forEach(el => obs.observe(el));
</script>

<style>
  .prose-custom h3 {
    font-family: 'Instrument Serif', serif;
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--dark);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-custom h3:first-child {
    margin-top: 0;
  }
  .prose-custom p {
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(26, 21, 35, 0.65);
    margin-bottom: 1rem;
  }
  .prose-custom strong {
    font-weight: 500;
    color: var(--dark);
  }
  .prose-custom blockquote {
    border-left: 3px solid var(--primary);
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    background: rgba(107, 92, 231, 0.04);
    border-radius: 0 0.75rem 0.75rem 0;
  }
  .prose-custom blockquote p {
    font-family: 'Instrument Serif', serif;
    font-size: 1.15rem;
    font-weight: 400;
    font-style: italic;
    color: var(--dark);
    margin-bottom: 0.5rem;
  }
  .prose-custom blockquote cite {
    font-family: 'DM Sans', sans-serif;
    font-style: normal;
    font-size: 0.8rem;
    color: rgba(26, 21, 35, 0.45);
  }
</style>
