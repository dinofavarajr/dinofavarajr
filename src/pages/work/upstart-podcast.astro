---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Upstart Podcast Case Study | Dino Favara Jr."
  description="Architected a single video concept that became a clear outlier on their channel. 24K views vs. a 1–2K average."
>
  <Nav />

  <main>
    <section class="max-w-3xl mx-auto px-6 pt-10">
      <a href="/work" class="inline-flex items-center gap-2 text-sm font-medium text-primary/70 hover:text-primary transition-colors duration-200">
        &larr; All case studies
      </a>
    </section>

    <section class="max-w-3xl mx-auto px-6 pt-8 pb-12">
      <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-purple-500/10 text-purple-700 tracking-wide mb-6">
        Podcast Clips
      </span>
      <h1 class="font-display text-[clamp(2rem,5vw,3.2rem)] leading-[1.1] tracking-tight text-dark mb-4">
        Upstart Podcast Shorts
      </h1>
      <p class="text-lg font-light text-dark/60 leading-relaxed max-w-xl">
        Architected a single video concept that became a clear outlier on their channel. 24K views vs. a 1–2K average.
      </p>
      <div class="flex flex-wrap gap-2 mt-6">
        {['Clip Selection', 'Concept Strategy', 'Editing Direction', 'Short-Form Optimization'].map(tag => (
          <span class="px-3 py-1.5 rounded-full border border-dark/10 bg-white/60 text-xs font-medium text-dark/55">{tag}</span>
        ))}
      </div>
    </section>

    <section class="stats-section max-w-4xl mx-auto px-6 pb-12">
      <div class="rounded-2xl border border-dark/8 bg-white/70 overflow-hidden">
        <div style="display:grid; grid-template-columns:1fr auto 1fr;">
          <div class="flex flex-col items-center justify-center py-6 px-8 text-center">
            <span class="text-[11px] font-medium uppercase tracking-widest text-dark/40 mb-3">Typical Video</span>
            <span class="font-display leading-none" style="font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1;" text-red-500">1–2K</span>
            <span class="mt-2 text-sm font-light text-dark/50">views per clip</span>
          </div>
          <div class="hidden md:flex items-center justify-center px-4"><span class="text-2xl text-dark/20">&rarr;</span></div>
          <div class="flex md:hidden items-center justify-center py-2"><span class="text-2xl text-dark/20">&darr;</span></div>
          <div class="flex flex-col items-center justify-center py-6 px-8 text-center bg-mint/8">
            <span class="text-[11px] font-medium uppercase tracking-widest text-dark/40 mb-3">My Concept</span>
            <span class="count-up font-display leading-none" style="font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1;" text-dark" data-value="24K">24K</span>
            <span class="mt-2 text-sm font-light text-dark/50">views (clear outlier)</span>
          </div>
        </div>
      </div>
    </section>

    <section class="stats-section max-w-4xl mx-auto px-6 pb-12">
      <div class="grid grid-cols-2 gap-4 max-w-xs">
        {[
          { value: '12–24x', label: 'Outlier Multiple' },
          { value: '24K', label: 'Views on One Clip' },
        ].map(m => (
          <div class="rounded-xl border border-dark/8 bg-white/60 p-5 text-center">
            <span class="count-up font-display text-3xl text-dark" data-value={m.value}>{m.value}</span>
            <p class="mt-1 text-[11px] font-medium uppercase tracking-widest text-dark/45">{m.label}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="max-w-3xl mx-auto px-6 pb-16">
      <article class="prose-custom">
        <h3>The Situation</h3>
        <p>A podcast with solid long-form content was posting short-form clips that averaged 1–2K views. The clips existed, but they weren't architected for discovery. Wrong moments selected, weak hooks, no platform-native concept development.</p>

        <h3>The Approach</h3>
        <p>I focused on concept-level strategy rather than just clip selection. Instead of pulling "interesting" moments from episodes, I identified the single highest-potential concept in the content library and built a clip around it with a specific hook structure, editing direction, and packaging designed for short-form discovery.</p>

        <h3>The Results</h3>
        <p>The clip I architected hit 24K views — a clear outlier on a channel where typical videos were getting 1–2K. It continues to outperform their standard content, proving that the difference between a 2K-view clip and a 24K-view clip isn't production quality. It's concept strategy.</p>
      </article>
    </section>

    <section class="max-w-3xl mx-auto px-6 pb-20">
      <div class="rounded-2xl border border-dark/8 bg-white/60 p-8 flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <p class="font-display text-xl text-dark">Want results like this?</p>
          <p class="text-sm font-light text-dark/55 mt-1">Let's talk about building your content engine.</p>
        </div>
        <a href="mailto:dino@mercurysocialmedia.com" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-primary text-off-white font-medium text-sm hover:bg-primary/90 hover:shadow-xl hover:shadow-primary/40 hover:-translate-y-0.5 transition-all duration-200 active:scale-95 whitespace-nowrap">
          Email me &rarr;
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  function animateCount(el: HTMLElement) {
    const target = el.dataset.value ?? '';
    const hasPlus = target.includes('+');
    const hasM = target.includes('M');
    const hasK = target.includes('K');
    const hasPercent = target.includes('%');
    const hasX = /^\d+(\.\d+)?x$/.test(target.replace('+', ''));
    const clean = target.replace(/[+MKx%,\s]/gi, '').trim();
    if (!/^\d+\.?\d*$/.test(clean)) return;
    const raw = parseFloat(clean);
    if (isNaN(raw)) return;
    const dur = 5000;
    const start = performance.now();
    const fmt = (n: number): string => {
      if (hasM) return (Math.round(n * 10) / 10) + 'M' + (hasPlus ? '+' : '');
      if (hasK) return Math.round(n) + 'K' + (hasPlus ? '+' : '');
      if (hasPercent) return Math.round(n).toLocaleString() + '%';
      if (hasX) return Math.round(n) + 'x';
      return Math.round(n).toLocaleString() + (hasPlus ? '+' : '');
    };
    const tick = (now: number) => {
      const progress = Math.min((now - start) / dur, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = fmt(eased * raw);
      if (progress < 1) requestAnimationFrame(tick);
      else el.textContent = target;
    };
    el.textContent = fmt(0);
    requestAnimationFrame(tick);
  }
  const obs = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      entry.target.querySelectorAll<HTMLElement>('.count-up').forEach(animateCount);
      obs.unobserve(entry.target);
    });
  }, { threshold: 0.3 });
  document.querySelectorAll<HTMLElement>('.stats-section').forEach(el => obs.observe(el));
</script>

<style>
  .prose-custom h3 { font-family: 'Instrument Serif', serif; font-size: 1.35rem; font-weight: 400; color: var(--dark); margin-top: 2rem; margin-bottom: 0.75rem; }
  .prose-custom h3:first-child { margin-top: 0; }
  .prose-custom p { font-size: 0.95rem; font-weight: 300; line-height: 1.75; color: rgba(26, 21, 35, 0.65); margin-bottom: 1rem; }
  .prose-custom strong { font-weight: 500; color: var(--dark); }
</style>
