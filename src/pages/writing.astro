---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import KitForm from '../components/KitForm.astro';

// Fetch and parse the 5 most recent posts from the RSS feed
interface Post {
  title: string;
  link: string;
  pubDate: string;
  description: string;
}

let posts: Post[] = [];

try {
  const res = await fetch('https://dinofavarajr.kit.com/posts.rss', {
    headers: { 'User-Agent': 'Mozilla/5.0 (compatible; Astro/RSS-parser)' },
  });

  if (res.ok) {
    const xml = await res.text();

    // Extract <item> blocks
    const itemMatches = xml.matchAll(/<item>([\s\S]*?)<\/item>/g);

    for (const match of itemMatches) {
      if (posts.length >= 5) break;
      const item = match[1];

      // Helper: extract tag content, handling CDATA
      const extract = (tag: string, src: string): string => {
        const re = new RegExp(`<${tag}[^>]*>(?:<!\\[CDATA\\[([\\s\\S]*?)\\]\\]>|([^<]*))</${tag}>`, 'i');
        const m = src.match(re);
        if (!m) return '';
        return (m[1] ?? m[2] ?? '').trim();
      };

      const rawTitle = extract('title', item);
      const rawLink  = extract('link', item) || (() => {
        const m = item.match(/<link>(.*?)<\/link>/i);
        return m ? m[1].trim() : '';
      })();
      const rawDate  = extract('pubDate', item);
      const rawDesc  = extract('description', item) || extract('content:encoded', item);

      // Strip HTML tags and truncate description
      const stripped = rawDesc
        .replace(/<[^>]+>/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
      const excerpt = stripped.length > 160
        ? stripped.slice(0, 157) + '…'
        : stripped;

      // Format date
      let pubDate = '';
      try {
        pubDate = new Date(rawDate).toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        });
      } catch {
        pubDate = rawDate;
      }

      posts.push({
        title: rawTitle,
        link: rawLink,
        pubDate,
        description: excerpt,
      });
    }
  }
} catch (err) {
  // Fall back to empty array — handled in template
  posts = [];
}
---

<Layout
  title="Writing | Dino Favara Jr."
  description="Essays, newsletters, and short-form ideas from Dino Favara Jr. Subscribe to The Yearbook or Short Form Secrets."
>
  <Nav />

  <main>
    <!-- ── Hero ── -->
    <section class="relative overflow-hidden pt-14 pb-10">
      <!-- Ambient blobs -->
      <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
        <div class="absolute -top-32 -left-32 w-[520px] h-[520px] rounded-full bg-primary/10 blur-[100px]"></div>
        <div class="absolute top-40 -right-20 w-[400px] h-[400px] rounded-full bg-periwinkle/15 blur-[80px]"></div>
        <div class="absolute bottom-0 left-1/3 w-[260px] h-[260px] rounded-full bg-mint/8 blur-[72px]"></div>
      </div>

      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-center gap-3 mb-5">
          <div class="h-px w-10 bg-primary/40 flex-shrink-0"></div>
          <span class="text-sm font-medium tracking-widest uppercase text-primary/80">
            Essays &amp; Newsletters
          </span>
        </div>
        <h1 class="font-display text-[clamp(2.6rem,6vw,4.5rem)] leading-[1.06] tracking-tight text-dark">
          Writing
        </h1>
        <p class="mt-4 text-[1.05rem] font-light text-dark/60 max-w-xl">
          Two newsletters. A bunch of posts. All trying to say something worth reading.
        </p>
      </div>
    </section>

    <!-- ── Newsletter Cards ── -->
    <section class="py-10 max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <!-- Card 1: The Yearbook -->
        <div class="rounded-2xl border border-dark/8 bg-white/60 backdrop-blur-sm p-8 flex flex-col gap-5 shadow-sm">
          <!-- Top accent line -->
          <div class="h-0.5 w-12 rounded-full bg-gradient-to-r from-primary to-periwinkle"></div>

          <div class="flex flex-wrap items-center gap-3">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-primary/10 text-primary tracking-wide">
              Personal · Life · Creativity
            </span>
          </div>

          <div>
            <h2 class="font-display text-2xl text-dark mb-2">The Yearbook</h2>
            <p class="text-[0.95rem] font-light text-dark/65 leading-relaxed">
              Lessons on life, creativity, and growing up, written for my kids to find someday.
            </p>
          </div>

          <div class="mt-auto space-y-4">
            <KitForm
              formId="9211740"
              buttonStyle="purple"
              instanceId="yearbook-writing-form"
            />
            <a
              href="https://theyearbook.beehiiv.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block text-sm text-primary underline underline-offset-4 hover:text-primary/80 transition-colors"
            >
              Browse past issues →
            </a>
          </div>
        </div>

        <!-- Card 2: Short Form Secrets -->
        <div class="rounded-2xl border border-dark/8 bg-white/60 backdrop-blur-sm p-8 flex flex-col gap-5 shadow-sm">
          <div class="h-0.5 w-12 rounded-full bg-gradient-to-r from-mint to-periwinkle"></div>

          <div class="flex flex-wrap items-center gap-3">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-dark/8 text-dark/70 tracking-wide">
              Video · Strategy · Growth
            </span>
            <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-mint/20 text-dark/80 tracking-wide">
              470+ subscribers
            </span>
          </div>

          <div>
            <h2 class="font-display text-2xl text-dark mb-2">Short Form Secrets</h2>
            <p class="text-[0.95rem] font-light text-dark/65 leading-relaxed">
              The exact methods to grow your audience with short-form video, no fluff.
            </p>
          </div>

          <div class="mt-auto">
            <KitForm
              formId="3880843"
              buttonStyle="purple"
              instanceId="sfs-form"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- ── Post List ── -->
    <section class="py-16 max-w-6xl mx-auto px-6">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-px w-10 bg-primary/40 flex-shrink-0"></div>
        <span class="text-sm font-medium tracking-widest uppercase text-primary/70">
          All posts
        </span>
      </div>
      <h2 class="font-display text-3xl text-dark mb-8">The archive</h2>

      <!-- Filter Tabs -->
      <div class="flex flex-wrap gap-2 mb-8" id="filter-tabs" role="tablist" aria-label="Filter posts by category">
        {[
          { label: 'All',               value: 'all'              },
          { label: 'Disney',            value: 'Disney'           },
          { label: 'YouTube Strategy',  value: 'YouTube Strategy' },
          { label: 'Personal Growth',   value: 'Personal Growth'  },
        ].map(tab => (
          <button
            role="tab"
            data-filter={tab.value}
            aria-selected={tab.value === 'all' ? 'true' : 'false'}
            class:list={[
              'filter-tab px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-200 border',
              tab.value === 'all'
                ? 'bg-primary text-white border-primary'
                : 'bg-white/60 text-dark/60 border-dark/10 hover:border-primary/30 hover:text-dark',
            ]}
          >
            {tab.label}
          </button>
        ))}
      </div>

      <!-- Post Rows -->
      <div id="post-list" class="divide-y divide-dark/6 rounded-2xl border border-dark/8 bg-white/50 overflow-hidden">

        <!-- Disney -->
        <article data-category="Disney" class="post-row group flex items-center gap-4 px-5 py-4 hover:bg-primary/4 transition-colors">
          <span class="text-amber-400 text-sm flex-shrink-0 w-4" aria-label="Recommended read">★</span>
          <a href="#" class="flex-1 font-medium text-dark group-hover:text-primary transition-colors text-[0.95rem] leading-snug">
            Why Walt Disney's "Plus It" Philosophy Changed How I Create
          </a>
          <span class="hidden sm:inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary/10 text-primary flex-shrink-0">Disney</span>
          <time class="text-xs text-dark/40 font-medium flex-shrink-0 tabular-nums">Mar 10, 2025</time>
        </article>

        <!-- YouTube Strategy -->
        <article data-category="YouTube Strategy" class="post-row group flex items-center gap-4 px-5 py-4 hover:bg-primary/4 transition-colors">
          <span class="text-amber-400 text-sm flex-shrink-0 w-4" aria-label="Recommended read">★</span>
          <a href="#" class="flex-1 font-medium text-dark group-hover:text-primary transition-colors text-[0.95rem] leading-snug">
            The Hook Formula That Grew My Channel by 40% in 30 Days
          </a>
          <span class="hidden sm:inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-mint/20 text-dark/70 flex-shrink-0">YouTube Strategy</span>
          <time class="text-xs text-dark/40 font-medium flex-shrink-0 tabular-nums">Feb 22, 2025</time>
        </article>

        <!-- Personal Growth -->
        <article data-category="Personal Growth" class="post-row group flex items-center gap-4 px-5 py-4 hover:bg-primary/4 transition-colors">
          <span class="text-amber-400 text-sm flex-shrink-0 w-4" aria-label="Recommended read">★</span>
          <a href="#" class="flex-1 font-medium text-dark group-hover:text-primary transition-colors text-[0.95rem] leading-snug">
            What My Kids Are Teaching Me About Starting Things
          </a>
          <span class="hidden sm:inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-periwinkle/20 text-dark/70 flex-shrink-0">Personal Growth</span>
          <time class="text-xs text-dark/40 font-medium flex-shrink-0 tabular-nums">Feb 8, 2025</time>
        </article>

        <!-- Disney -->
        <article data-category="Disney" class="post-row group flex items-center gap-4 px-5 py-4 hover:bg-primary/4 transition-colors">
          <span class="flex-shrink-0 w-4"></span>
          <a href="#" class="flex-1 font-medium text-dark group-hover:text-primary transition-colors text-[0.95rem] leading-snug">
            EPCOT and the Lost Dream of Tomorrow
          </a>
          <span class="hidden sm:inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary/10 text-primary flex-shrink-0">Disney</span>
          <time class="text-xs text-dark/40 font-medium flex-shrink-0 tabular-nums">Jan 29, 2025</time>
        </article>

        <!-- YouTube Strategy -->
        <article data-category="YouTube Strategy" class="post-row group flex items-center gap-4 px-5 py-4 hover:bg-primary/4 transition-colors">
          <span class="flex-shrink-0 w-4"></span>
          <a href="#" class="flex-1 font-medium text-dark group-hover:text-primary transition-colors text-[0.95rem] leading-snug">
            Thumbnail Psychology: Why Your Face Matters More Than Your Title
          </a>
          <span class="hidden sm:inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-mint/20 text-dark/70 flex-shrink-0">YouTube Strategy</span>
          <time class="text-xs text-dark/40 font-medium flex-shrink-0 tabular-nums">Jan 14, 2025</time>
        </article>

        <!-- Personal Growth -->
        <article data-category="Personal Growth" class="post-row group flex items-center gap-4 px-5 py-4 hover:bg-primary/4 transition-colors">
          <span class="flex-shrink-0 w-4"></span>
          <a href="#" class="flex-1 font-medium text-dark group-hover:text-primary transition-colors text-[0.95rem] leading-snug">
            The Art of Starting Before You're Ready
          </a>
          <span class="hidden sm:inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-periwinkle/20 text-dark/70 flex-shrink-0">Personal Growth</span>
          <time class="text-xs text-dark/40 font-medium flex-shrink-0 tabular-nums">Dec 19, 2024</time>
        </article>

        <!-- YouTube Strategy -->
        <article data-category="YouTube Strategy" class="post-row group flex items-center gap-4 px-5 py-4 hover:bg-primary/4 transition-colors">
          <span class="flex-shrink-0 w-4"></span>
          <a href="#" class="flex-1 font-medium text-dark group-hover:text-primary transition-colors text-[0.95rem] leading-snug">
            How to Write a Short-Form Script in 20 Minutes Flat
          </a>
          <span class="hidden sm:inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-mint/20 text-dark/70 flex-shrink-0">YouTube Strategy</span>
          <time class="text-xs text-dark/40 font-medium flex-shrink-0 tabular-nums">Dec 3, 2024</time>
        </article>

        <!-- Disney -->
        <article data-category="Disney" class="post-row group flex items-center gap-4 px-5 py-4 hover:bg-primary/4 transition-colors">
          <span class="flex-shrink-0 w-4"></span>
          <a href="#" class="flex-1 font-medium text-dark group-hover:text-primary transition-colors text-[0.95rem] leading-snug">
            What Imagineers Understood About Storytelling That Most Creators Miss
          </a>
          <span class="hidden sm:inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary/10 text-primary flex-shrink-0">Disney</span>
          <time class="text-xs text-dark/40 font-medium flex-shrink-0 tabular-nums">Nov 18, 2024</time>
        </article>

        <!-- No results fallback (hidden by default) -->
        <div id="no-results" class="hidden px-5 py-12 text-center text-sm text-dark/40 font-light">
          No posts in this category yet. Check back soon.
        </div>

      </div>
    </section>

    <script>
      const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
      const rows = document.querySelectorAll<HTMLElement>('.post-row');
      const noResults = document.getElementById('no-results')!;

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const filter = tab.dataset.filter!;

          // Update tab styles
          tabs.forEach(t => {
            const active = t.dataset.filter === filter;
            t.setAttribute('aria-selected', String(active));
            t.classList.toggle('bg-primary', active);
            t.classList.toggle('text-white', active);
            t.classList.toggle('border-primary', active);
            t.classList.toggle('bg-white/60', !active);
            t.classList.toggle('text-dark/60', !active);
            t.classList.toggle('border-dark/10', !active);
          });

          // Show / hide rows
          let visible = 0;
          rows.forEach(row => {
            const show = filter === 'all' || row.dataset.category === filter;
            row.style.display = show ? '' : 'none';
            if (show) visible++;
          });

          noResults.classList.toggle('hidden', visible > 0);
        });
      });
    </script>
  </main>

  <Footer />
</Layout>
