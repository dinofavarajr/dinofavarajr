                <polygon points="0,-30 -5,-13 0,-9 5,-13" fill="#8B6914"/>
                <polygon points="0,30 -5,13 0,9 5,13" fill="#C4A97A" opacity="0.65"/>
                <polygon points="-30,0 -13,-5 -9,0 -13,5" fill="#C4A97A" opacity="0.65"/>
                <polygon points="30,0 13,-5 9,0 13,5" fill="#C4A97A" opacity="0.65"/>
                <line x1="-21" y1="-21" x2="21" y2="21" stroke="#C4A97A" stroke-width="0.6" opacity="0.35"/>
                <line x1="21" y1="-21" x2="-21" y2="21" stroke="#C4A97A" stroke-width="0.6" opacity="0.35"/>
                <text x="0" y="-16" text-anchor="middle" font-size="9" fill="#6B4A14" font-weight="bold">N</text>
                <text x="0" y="22" text-anchor="middle" font-size="7" fill="#8B6914" opacity="0.8">S</text>
                <text x="-20" y="3" text-anchor="middle" font-size="7" fill="#8B6914" opacity="0.8">W</text>
                <text x="20" y="3" text-anchor="middle" font-size="7" fill="#8B6914" opacity="0.8">E</text>
              </g>
              <text x="742" y="115" text-anchor="middle" font-size="6" font-style="italic" fill="#8B6914" opacity="0.55">True North</text>

              {parks.animal_kingdom.rides.map(ride => (
                <g
                  class="ride-pin-group"
                  data-park="animal_kingdom"
                  data-name={ride.name}
                  data-land={ride.land}
                  data-reviewed={ride.reviewed ? "true" : "false"}
                  data-stars={ride.stars?.toString() ?? ""}
                  data-tags={ride.tags?.join(",") ?? ""}
                  data-take={ride.take ?? ""}
                  data-type={ride.type}
                  data-video={ride.video !== false ? "true" : "false"}
                  style="cursor:pointer"
                  role="button"
                  tabindex="0"
                  aria-label={ride.name}
                >
                  <circle cx={ride.x} cy={ride.y} r="13" fill="transparent"/>
                  {ride.reviewed ? (
                    ride.type === 'special' ? (
                      <>
                        <circle cx={ride.x} cy={ride.y} r="9" fill="white" opacity="0.8"/>
                        <polygon points={`${ride.x},${ride.y-8} ${ride.x+7},${ride.y} ${ride.x},${ride.y+8} ${ride.x-7},${ride.y}`} fill="#C4A97A" stroke="#8B6914" stroke-width="1.5"/>
                      </>
                    ) : (
                      <>
                        <circle cx={ride.x} cy={ride.y} r="9" fill="white" opacity="0.8"/>
                        <circle cx={ride.x} cy={ride.y} r="7.5" fill="#A89FF5" stroke="#6B5CE7" stroke-width="2"/>
                      </>
                    )
                  ) : (
                    <>
                      <circle cx={ride.x} cy={ride.y} r="9" fill="white" opacity="0.5"/>
                      <circle cx={ride.x} cy={ride.y} r="7" fill="none" stroke="#9CA3AF" stroke-width="1.5"/>
                    </>
                  )}
                </g>
              ))}
            </svg>
          </div>

        </div><!-- /map-wrapper -->

        <!-- Map Legend -->
        <div class="mt-6 flex flex-wrap items-center gap-5 justify-center">
          <div class="flex items-center gap-2 text-sm text-dark/60">
            <svg width="16" height="16" viewBox="0 0 16 16"><circle cx="8" cy="8" r="6" fill="#A89FF5" stroke="#6B5CE7" stroke-width="2"/></svg>
            Reviewed on camera
          </div>
          <div class="flex items-center gap-2 text-sm text-dark/60">
            <svg width="16" height="16" viewBox="0 0 16 16"><polygon points="8,2 14,8 8,14 2,8" fill="#C4A97A" stroke="#8B6914" stroke-width="1.5"/></svg>
            Special Experience
          </div>
          <div class="flex items-center gap-2 text-sm text-dark/60">
            <svg width="16" height="16" viewBox="0 0 16 16"><circle cx="8" cy="8" r="6" fill="none" stroke="#9CA3AF" stroke-width="1.5"/></svg>
            Not yet reviewed
          </div>
        </div>

        <!-- Tag Legend -->
        <div class="mt-5 flex flex-wrap gap-2 justify-center">
          <span class="tag-pill" style="background:#FEF3C7;color:#92400E">🧒 Kid Friendly</span>
          <span class="tag-pill" style="background:#EDE9FE;color:#5B21B6">⭐ Cornerstone Experience</span>
          <span class="tag-pill" style="background:#FEE2E2;color:#991B1B">😒 Overrated</span>
          <span class="tag-pill" style="background:#DBEAFE;color:#1E40AF">🎿 Single Rider Available</span>
          <span class="tag-pill" style="background:#E0F2FE;color:#0C4A6E">❄️ Air Conditioning Haven</span>
        </div>

      </div>
    </section>

    <!-- ── SLIDE-OUT DETAIL PANEL ── -->
    <div id="ride-panel" class="ride-panel" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Ride details">
      <div class="ride-panel-inner">
        <button id="panel-close" class="panel-close-btn" aria-label="Close panel">✕</button>
        <div id="panel-content" class="panel-content">
          <!-- Filled by JS -->
        </div>
      </div>
    </div>
    <div id="panel-overlay" class="panel-overlay" aria-hidden="true"></div>

    <!-- ── PLANNER CTA ── -->
    <section class="bg-[#1A1523] py-10 px-6">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-[#FAF9F5] text-2xl font-display tracking-tight">Let's plan your day in 5 minutes so you can stop Googling and just go.</p>
      </div>
    </section>

    <!-- ── DAY PLANNER ── -->
    <section class="bg-[#FAF9F5] py-20 px-6">
      <div class="max-w-3xl mx-auto">
        <div class="flex items-center gap-3 mb-4">
          <div class="h-px w-10 bg-[#6B5CE7]/40 flex-shrink-0"></div>
          <span class="text-xs font-medium tracking-widest uppercase text-[#6B5CE7]/70">Day Planner</span>
        </div>
        <h2 class="font-display text-3xl text-dark mb-2">Build Your Day</h2>
        <p class="text-sm font-light text-dark/50 mb-8">Based on Dino's real ratings and 100+ park visits.</p>

        <div class="bg-white rounded-2xl border border-dark/8 p-8 shadow-sm">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-6">
            <div class="flex flex-col gap-2">
              <label for="who-coming" class="text-sm font-medium text-dark/70">Who's coming?</label>
              <select id="who-coming" class="planner-select">
                <option value="solo">Just me (solo)</option>
                <option value="couple">Me + someone</option>
                <option value="kids">Kids in the mix</option>
                <option value="group">Big group</option>
              </select>
            </div>
            <div class="flex flex-col gap-2">
              <label for="thrill-level" class="text-sm font-medium text-dark/70">Thrill level?</label>
              <select id="thrill-level" class="planner-select">
                <option value="chill">Keep it chill</option>
                <option value="mix">Mix it up</option>
                <option value="send">Send it</option>
              </select>
            </div>
            <div class="flex flex-col gap-2">
              <label for="trip-origin" class="text-sm font-medium text-dark/70">Visiting from out of town?</label>
              <select id="trip-origin" class="planner-select">
                <option value="out-of-town">Yes, traveled here</option>
                <option value="local">Nope, I'm local</option>
              </select>
            </div>
            <div class="flex flex-col gap-2">
              <label for="only-trip" class="text-sm font-medium text-dark/70">Only Disney trip this year?</label>
              <select id="only-trip" class="planner-select">
                <option value="yes">Yes, this is it</option>
                <option value="no">No, I'll be back</option>
              </select>
            </div>
            <div class="flex flex-col gap-2">
              <label for="which-park" class="text-sm font-medium text-dark/70">Which park?</label>
              <select id="which-park" class="planner-select">
                <option value="magic_kingdom">Magic Kingdom</option>
                <option value="epcot">EPCOT</option>
                <option value="hollywood_studios">Hollywood Studios</option>
                <option value="animal_kingdom">Animal Kingdom</option>
              </select>
            </div>
            <div class="flex flex-col gap-2">
              <label for="passholder" class="text-sm font-medium text-dark/70">Annual Passholder?</label>
              <select id="passholder" class="planner-select">
                <option value="no">No</option>
                <option value="yes">Yes</option>
              </select>
            </div>
            <div class="flex flex-col gap-2">
              <label for="resort" class="text-sm font-medium text-dark/70">Staying where?</label>
              <select id="resort" class="planner-select">
                <option value="on-property">On Disney property</option>
                <option value="off-property">Off property</option>
                <option value="day-trip">Not staying (day trip)</option>
              </select>
            </div>
            <div id="kids-age-row" class="flex flex-col gap-2 hidden">
              <label for="kids-age" class="text-sm font-medium text-dark/70">Kids' age range?</label>
              <select id="kids-age" class="planner-select">
                <option value="toddlers">Toddlers (2–4)</option>
                <option value="young">Young kids (5–8)</option>
                <option value="tweens">Tweens / teens (9+)</option>
                <option value="mixed">Mixed ages</option>
              </select>
            </div>
            <div class="flex flex-col gap-2">
              <label for="visit-frequency" class="text-sm font-medium text-dark/70">How often do you go to Disney?</label>
              <select id="visit-frequency" class="planner-select">
                <option value="first">First time ever</option>
                <option value="1-5">1–5 times</option>
                <option value="5-20">5–20 times</option>
                <option value="20plus">20+ times</option>
              </select>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-5 mb-6">
            <div class="flex flex-col gap-2">
              <label for="trip-start" class="text-sm font-medium text-dark/70">Trip starts</label>
              <input type="date" id="trip-start" class="planner-date" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="trip-end" class="text-sm font-medium text-dark/70">Trip ends</label>
              <input type="date" id="trip-end" class="planner-date" />
            </div>
          </div>
          <button id="build-day-btn" class="w-full py-3.5 rounded-xl bg-[#6B5CE7] text-white font-medium text-sm hover:bg-[#5a4bd4] transition-colors duration-200">
            Build My Day →
          </button>
        </div>

        <!-- Planner Results -->
        <div id="planner-results" class="mt-8 hidden">
          <!-- Filled by JS -->
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* ── Park Tabs ── */
  .park-tab {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 9px 18px 9px 28px;
    background: #FAF9F5;
    border: 1.5px solid #C4A97A;
    border-radius: 4px 4px 0 0;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    color: #6B5CE7;
    cursor: pointer;
    transition: all 0.2s;
    outline: none;
  }
  .park-tab:hover {
    background: #f0ebdf;
    border-color: #A07840;
  }
  .park-tab.active {
    background: #6B5CE7;
    border-color: #6B5CE7;
    color: #FAF9F5;
  }
  .park-tab .hole {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    width: 7px;
    height: 7px;
    border-radius: 50%;
    border: 1.5px solid currentColor;
    opacity: 0.4;
  }

  /* ── Map wrapper ── */
  .map-wrapper {
    background: #F5EDD8;
    border-top: none;
  }

  /* ── Tag Pills ── */
  .tag-pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 500;
    font-family: 'DM Sans', system-ui, sans-serif;
  }

  /* ── Ride Pins hover ── */
  .ride-pin-group:hover circle,
  .ride-pin-group:focus circle {
    filter: brightness(1.1);
  }
  .ride-pin-group:focus {
    outline: none;
  }
  .ride-pin-group:focus-visible circle:last-child {
    stroke-width: 3;
  }

  /* ── Slide-out Panel ── */
  .ride-panel {
    position: fixed;
    top: 0;
    right: 0;
    height: 100%;
    width: min(420px, 100vw);
    background: #FAF9F5;
    box-shadow: -4px 0 30px rgba(26, 21, 35, 0.18);
    z-index: 200;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    overflow-y: auto;
  }
  .ride-panel.open {
    transform: translateX(0);
  }
  .ride-panel-inner {
    padding: 28px 28px 48px;
    position: relative;
  }
  .panel-close-btn {
    position: absolute;
    top: 18px;
    right: 18px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1.5px solid rgba(26,21,35,0.15);
    background: transparent;
    font-size: 13px;
