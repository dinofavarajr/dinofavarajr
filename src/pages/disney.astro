---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

type RideTag = 'kid-friendly' | 'cornerstone' | 'overrated' | 'single-rider' | 'ac-haven';
type RideType = 'ride' | 'special';

interface Ride {
  id: string;
  name: string;
  land: string;
  x: number;
  y: number;
  reviewed: boolean;
  stars?: number;
  tags?: RideTag[];
  take?: string;
  type: RideType;
  video?: boolean;
}

interface Park {
  name: string;
  emoji: string;
  rides: Ride[];
}

const parks: Record<string, Park> = {
  epcot: {
    name: 'EPCOT',
    emoji: '🌍',
    rides: [
      { id: 'mission-space-green', name: 'Mission: Space (Green)', land: 'World Discovery', x: 545, y: 398, reviewed: true, stars: 1, tags: ['single-rider'], take: "The Green mission is genuinely underrated, a solid space simulation that doesn't require a barf bag. Great for first-timers who want the full experience.", type: 'ride', video: false },
      { id: 'mission-space-orange', name: 'Mission: Space (Orange)', land: 'World Discovery', x: 598, y: 382, reviewed: true, stars: 4, tags: ['cornerstone'], take: "This is the real deal, intense, centrifugal, and surprisingly educational about what astronauts actually experience. Do not skip this one.", type: 'ride' },
      { id: 'figment', name: 'Journey into Imagination with Figment', land: 'World Celebration', x: 340, y: 388, reviewed: true, stars: 3, tags: ['kid-friendly', 'ac-haven'], take: "Nostalgia bait that mostly lands. Figment is a Disney icon and this ride coasts on pure vibes, but in a way that somehow works.", type: 'ride' },
      { id: 'spaceship-earth', name: 'Spaceship Earth', land: 'World Celebration', x: 400, y: 252, reviewed: false, type: 'ride' },
      { id: 'guardians', name: 'Guardians of the Galaxy: Cosmic Rewind', land: 'World Discovery', x: 618, y: 339, reviewed: false, type: 'ride' },
      { id: 'test-track', name: 'Test Track', land: 'World Discovery', x: 558, y: 426, reviewed: false, type: 'ride' },
      { id: 'soarin', name: "Soarin' Around the World", land: 'World Nature', x: 238, y: 424, reviewed: false, type: 'ride' },
      { id: 'living-land', name: 'Living with the Land', land: 'World Nature', x: 195, y: 448, reviewed: false, type: 'ride' },
      { id: 'seas-nemo', name: 'The Seas with Nemo & Friends', land: 'World Nature', x: 170, y: 392, reviewed: false, type: 'ride' },
      { id: 'turtle-talk', name: 'Turtle Talk with Crush', land: 'World Nature', x: 148, y: 432, reviewed: false, type: 'ride' },
      { id: 'frozen', name: 'Frozen Ever After', land: 'World Showcase', x: 200, y: 159, reviewed: false, type: 'ride' },
      { id: 'remy', name: "Remy's Ratatouille Adventure", land: 'World Showcase', x: 535, y: 171, reviewed: false, type: 'ride' },
      { id: 'gran-fiesta', name: 'Gran Fiesta Tour', land: 'World Showcase', x: 155, y: 129, reviewed: false, type: 'ride' },
    ]
  },
  magic_kingdom: {
    name: 'Magic Kingdom',
    emoji: '🏰',
    rides: [
      { id: 'speedway', name: 'Tomorrowland Speedway', land: 'Tomorrowland', x: 618, y: 348, reviewed: true, stars: 2, tags: ['kid-friendly'], take: "It's a go-kart doing 7mph on a rail and your kid will absolutely lose their mind for it. You will not. That's the deal and it's fine.", type: 'ride' },
      { id: 'jungle-cruise', name: 'Jungle Cruise', land: 'Adventureland', x: 262, y: 445, reviewed: true, stars: 3.5, tags: ['cornerstone'], take: "The rating depends entirely on your Skipper. A transcendent one makes this a 5-star experience. An average one makes it a 2. Pray accordingly.", type: 'ride' },
      { id: 'festival-of-fantasy', name: 'Festival of Fantasy Parade', land: 'Main Street, U.S.A.', x: 400, y: 480, reviewed: true, stars: 5, tags: ['cornerstone'], take: "The single best thing you can do at Walt Disney World. Find a spot 30 minutes early, stand your ground, and just let it absolutely destroy you.", type: 'special' },
      { id: 'tron', name: 'TRON Lightcycle / Run', land: 'Tomorrowland', x: 590, y: 192, reviewed: false, type: 'ride' },
      { id: 'space-mountain', name: 'Space Mountain', land: 'Tomorrowland', x: 642, y: 278, reviewed: false, type: 'ride' },
      { id: 'buzz', name: "Buzz Lightyear's Space Ranger Spin", land: 'Tomorrowland', x: 568, y: 318, reviewed: false, type: 'ride' },
      { id: 'peoplemover', name: 'Tomorrowland Transit Authority PeopleMover', land: 'Tomorrowland', x: 598, y: 252, reviewed: false, type: 'ride' },
      { id: 'little-mermaid', name: 'Under the Sea: Journey of The Little Mermaid', land: 'Fantasyland', x: 505, y: 218, reviewed: true, stars: 3.3, tags: ['kid-friendly', 'cornerstone'], take: "A charming dark ride that's better than it has any right to be. The practical effects mixed with projections work together in a way that genuinely hits.", type: 'ride' },
      { id: 'ariel-grotto', name: "Ariel's Grotto (Meet & Greet)", land: 'Fantasyland', x: 535, y: 200, reviewed: true, stars: 3, tags: ['kid-friendly'], take: "A solid character meet. Ariel is engaged, the theming is lovely, and kids absolutely lose their minds for it. Worth it if you have little ones.", type: 'special' },
      { id: 'seven-dwarfs', name: 'Seven Dwarfs Mine Train', land: 'Fantasyland', x: 475, y: 182, reviewed: false, type: 'ride' },
      { id: 'small-world', name: "It's a Small World", land: 'Fantasyland', x: 398, y: 135, reviewed: false, type: 'ride' },
      { id: 'peter-pan', name: "Peter Pan's Flight", land: 'Fantasyland', x: 352, y: 172, reviewed: false, type: 'ride' },
      { id: 'dumbo', name: 'Dumbo the Flying Elephant', land: 'Fantasyland', x: 328, y: 215, reviewed: false, type: 'ride' },
      { id: 'haunted-mansion', name: 'Haunted Mansion', land: 'Liberty Square', x: 268, y: 268, reviewed: false, type: 'ride' },
      { id: 'pirates', name: 'Pirates of the Caribbean', land: 'Adventureland', x: 228, y: 428, reviewed: false, type: 'ride' },
      { id: 'tiki-room', name: "Walt Disney's Enchanted Tiki Room", land: 'Adventureland', x: 192, y: 462, reviewed: false, type: 'ride' },
      { id: 'big-thunder', name: 'Big Thunder Mountain Railroad', land: 'Frontierland', x: 192, y: 358, reviewed: false, type: 'ride' },
      { id: 'tianas', name: "Tiana's Bayou Adventure", land: 'Frontierland', x: 228, y: 392, reviewed: false, type: 'ride' },
      { id: 'country-bear', name: 'Country Bear Jamboree', land: 'Frontierland', x: 238, y: 338, reviewed: false, type: 'ride' },
      { id: 'liberty-belle', name: 'Liberty Belle Riverboat', land: 'Liberty Square', x: 295, y: 305, reviewed: false, type: 'ride' },
    ]
  },
  hollywood_studios: {
    name: 'Hollywood Studios',
    emoji: '🎬',
    rides: [
      { id: 'rise-resistance', name: 'Star Wars: Rise of the Resistance', land: "Galaxy's Edge", x: 162, y: 162, reviewed: false, type: 'ride' },
      { id: 'millennium-falcon', name: 'Millennium Falcon: Smugglers Run', land: "Galaxy's Edge", x: 228, y: 208, reviewed: false, type: 'ride' },
      { id: 'slinky-dog', name: 'Slinky Dog Dash', land: 'Toy Story Land', x: 585, y: 268, reviewed: false, type: 'ride' },
      { id: 'toy-story-mania', name: 'Toy Story Mania!', land: 'Toy Story Land', x: 542, y: 318, reviewed: false, type: 'ride' },
      { id: 'alien-swirling', name: 'Alien Swirling Saucers', land: 'Toy Story Land', x: 612, y: 312, reviewed: false, type: 'ride' },
      { id: 'rock-roller', name: "Rock 'n' Roller Coaster", land: 'Sunset Boulevard', x: 625, y: 392, reviewed: false, type: 'ride' },
      { id: 'tower-terror', name: 'The Twilight Zone Tower of Terror', land: 'Sunset Boulevard', x: 585, y: 452, reviewed: false, type: 'ride' },
      { id: 'muppets', name: "Muppet*Vision 3D", land: 'Grand Avenue', x: 415, y: 372, reviewed: false, type: 'ride' },
      { id: 'indiana-jones', name: 'Indiana Jones Epic Stunt Spectacular', land: 'Echo Lake', x: 292, y: 348, reviewed: false, type: 'ride' },
      { id: 'star-tours', name: 'Star Tours — The Adventures Continue', land: 'Echo Lake', x: 308, y: 392, reviewed: false, type: 'ride' },
      { id: 'mickey-runaway', name: "Mickey & Minnie's Runaway Railway", land: 'Hollywood Boulevard', x: 415, y: 282, reviewed: false, type: 'ride' },
    ]
  },
  animal_kingdom: {
    name: 'Animal Kingdom',
    emoji: '🦁',
    rides: [
      { id: 'navi-river', name: "Na'vi River Journey", land: 'Pandora', x: 255, y: 445, reviewed: true, stars: 1, tags: ['overrated', 'ac-haven'], take: "The animatronic Shaman at the end is legitimately one of the most impressive things Disney has ever built. Then you look at the 90-minute wait and do the math.", type: 'ride' },
      { id: 'flight-of-passage', name: 'Avatar Flight of Passage', land: 'Pandora', x: 212, y: 408, reviewed: false, type: 'ride' },
      { id: 'kilimanjaro', name: 'Kilimanjaro Safaris', land: 'Africa', x: 352, y: 162, reviewed: false, type: 'ride' },
      { id: 'gorilla-falls', name: 'Gorilla Falls Exploration Trail', land: 'Africa', x: 392, y: 198, reviewed: false, type: 'ride' },
      { id: 'expedition-everest', name: 'Expedition Everest', land: 'Asia', x: 572, y: 212, reviewed: false, type: 'ride' },
      { id: 'kali-river', name: 'Kali River Rapids', land: 'Asia', x: 522, y: 182, reviewed: false, type: 'ride' },
      { id: 'maharajah-trek', name: 'Maharajah Jungle Trek', land: 'Asia', x: 588, y: 262, reviewed: false, type: 'ride' },
      { id: 'dinosaur', name: 'DINOSAUR', land: 'DinoLand U.S.A.', x: 578, y: 382, reviewed: false, type: 'ride' },
      { id: 'primeval-whirl', name: 'Primeval Whirl', land: 'DinoLand U.S.A.', x: 552, y: 438, reviewed: false, type: 'ride' },
      { id: 'bugs-life', name: "It's Tough to be a Bug!", land: 'Discovery Island', x: 398, y: 292, reviewed: false, type: 'ride' },
    ]
  }
};
---

<Layout
  title="Disney Field Guide | Dino Favara Jr."
  description="100+ visits. No sponsors. Real opinions on every ride at Walt Disney World. reviewed on camera, one ride at a time."
>
  <Nav />

  <main>

    <!-- ── HERO ── -->
    <section class="relative overflow-hidden bg-[#1A1523] py-24">
      <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-[#A89FF5]/20 blur-[120px]"></div>
        <div class="absolute top-20 -right-20 w-[400px] h-[400px] rounded-full bg-[#6B5CE7]/25 blur-[100px]"></div>
        <div class="absolute bottom-0 left-1/2 w-[500px] h-[300px] rounded-full bg-[#A89FF5]/10 blur-[80px] -translate-x-1/2"></div>
      </div>

      <div class="relative z-10 max-w-4xl mx-auto px-6 text-center flex flex-col items-center gap-5">
        <h1 class="font-display text-[clamp(2.8rem,7vw,5.5rem)] leading-[1.05] tracking-tight text-[#FAF9F5]">
          Dino's Disney<br />Field Guide
        </h1>

        <div class="flex items-center gap-2 mt-2">
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-[#A89FF5]/15 border border-[#A89FF5]/25 text-[#A89FF5] text-xs font-medium">
            <span class="w-1.5 h-1.5 rounded-full bg-[#A89FF5] animate-pulse"></span>
            Map grows with every trip
          </span>
        </div>
      </div>
    </section>

    <!-- ── UNDER CONSTRUCTION BANNER ── -->
    <div class="relative bg-[#2A1F0E] border-y-4 border-[#F5C842] overflow-hidden">
      <!-- diagonal stripe pattern -->
      <div class="absolute inset-0 opacity-[0.07]" style="background-image: repeating-linear-gradient(45deg, #F5C842 0px, #F5C842 12px, transparent 12px, transparent 36px);" aria-hidden="true"></div>
      <div class="relative z-10 max-w-3xl mx-auto px-6 py-7 flex flex-col sm:flex-row items-center gap-4 text-center sm:text-left">
        <span class="text-4xl select-none flex-shrink-0" aria-hidden="true">🚧</span>
        <div>
          <p class="text-[#F5C842] font-display text-lg leading-snug tracking-wide">
            * Under Construction *
          </p>
          <p class="text-[#F5C842]/60 text-sm font-light mt-1 leading-relaxed italic">
            "We keep moving forward, opening new doors, and doing new things, because we're curious, and curiosity keeps leading us down new paths."
            <span class="not-italic font-medium text-[#F5C842]/50"> Walt Disney</span>
          </p>
        </div>
        <span class="text-4xl select-none flex-shrink-0 sm:ml-auto" aria-hidden="true">🚧</span>
      </div>
    </div>

    <!-- ── PARK TABS + MAP ── -->
    <section class="bg-[#FAF9F5] pt-12 pb-16">
      <div class="max-w-6xl mx-auto px-6">

        <!-- Disclaimer -->
        <p class="text-center text-sm italic text-dark/45 mb-8 font-light">
          These are my real opinions from real visits. Nobody paid me to say any of this, and I've never once eaten at the Rainforest Cafe.
        </p>

        <!-- Park Tabs -->
        <div class="flex flex-wrap gap-2 justify-center mb-0" role="tablist" aria-label="Select a park">
          {Object.entries(parks).map(([key, park], i) => (
            <button
              class={`park-tab ${i === 0 ? 'active' : ''}`}
              data-park={key}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
            >
              <span class="hole" aria-hidden="true"></span>
              {park.emoji} {park.name}
            </button>
          ))}
        </div>

        <!-- Map Container -->
        <div class="map-wrapper rounded-b-2xl rounded-tr-2xl overflow-hidden shadow-lg border border-[#C4A97A]/40">

          <!-- EPCOT Map -->
          <div id="map-epcot" class="park-map active" data-park="epcot">
            <svg viewBox="0 0 800 520" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto block" style="font-family: Georgia, 'Times New Roman', serif;">
              <defs>
                <filter id="ep-rough" x="-8%" y="-8%" width="116%" height="116%">
                  <feTurbulence type="fractalNoise" baseFrequency="0.04" numOctaves="3" seed="7" result="noise"/>
                  <feDisplacementMap in="SourceGraphic" in2="noise" scale="2.5" xChannelSelector="R" yChannelSelector="G"/>
                </filter>
              </defs>

              <rect width="800" height="520" fill="#F5EDD8"/>
              <rect width="800" height="520" fill="none" stroke="#D4B870" stroke-width="18" opacity="0.08"/>

              <!-- Double vintage border -->
              <rect x="5" y="5" width="790" height="510" fill="none" stroke="#C4A97A" stroke-width="2" opacity="0.75"/>
              <rect x="14" y="14" width="772" height="492" fill="none" stroke="#C4A97A" stroke-width="0.75" opacity="0.38"/>
              <!-- Corner ornaments -->
              <line x1="5" y1="5" x2="58" y2="5" stroke="#C4A97A" stroke-width="2.5"/><line x1="5" y1="5" x2="5" y2="58" stroke="#C4A97A" stroke-width="2.5"/><circle cx="5" cy="5" r="4" fill="#C4A97A"/><line x1="14" y1="30" x2="30" y2="14" stroke="#C4A97A" stroke-width="0.8" opacity="0.5"/>
              <line x1="795" y1="5" x2="742" y2="5" stroke="#C4A97A" stroke-width="2.5"/><line x1="795" y1="5" x2="795" y2="58" stroke="#C4A97A" stroke-width="2.5"/><circle cx="795" cy="5" r="4" fill="#C4A97A"/><line x1="786" y1="30" x2="770" y2="14" stroke="#C4A97A" stroke-width="0.8" opacity="0.5"/>
              <line x1="5" y1="515" x2="58" y2="515" stroke="#C4A97A" stroke-width="2.5"/><line x1="5" y1="515" x2="5" y2="462" stroke="#C4A97A" stroke-width="2.5"/><circle cx="5" cy="515" r="4" fill="#C4A97A"/><line x1="14" y1="490" x2="30" y2="506" stroke="#C4A97A" stroke-width="0.8" opacity="0.5"/>
              <line x1="795" y1="515" x2="742" y2="515" stroke="#C4A97A" stroke-width="2.5"/><line x1="795" y1="515" x2="795" y2="462" stroke="#C4A97A" stroke-width="2.5"/><circle cx="795" cy="515" r="4" fill="#C4A97A"/><line x1="786" y1="490" x2="770" y2="506" stroke="#C4A97A" stroke-width="0.8" opacity="0.5"/>

              <!-- Title -->
              <line x1="258" y1="28" x2="325" y2="28" stroke="#C4A97A" stroke-width="0.75" opacity="0.6"/>
              <text x="400" y="33" text-anchor="middle" font-size="13" fill="#6B4A14" letter-spacing="6" font-weight="bold" font-style="italic">EPCOT</text>
              <line x1="475" y1="28" x2="542" y2="28" stroke="#C4A97A" stroke-width="0.75" opacity="0.6"/>

              <!-- ── WORLD SHOWCASE — horseshoe shape (top of map, opening faces down) ── -->
              <path d="M 148,200 C 124,184 110,151 114,121 C 118,91 140,68 170,57 C 200,47 238,48 265,62 C 288,73 302,91 314,109 C 324,126 334,138 358,144 C 378,152 392,156 400,156 C 408,156 422,152 442,144 C 466,138 476,126 486,109 C 498,91 512,73 535,62 C 562,48 600,47 630,57 C 660,68 682,91 686,121 C 690,151 676,184 652,200 C 628,211 595,225 558,225 C 520,225 476,219 446,210 C 428,205 415,202 400,202 C 385,202 372,205 354,210 C 324,219 280,225 242,225 C 204,225 170,211 148,200 Z" fill="#D0D8E8" stroke="#7888A8" stroke-width="1.3" filter="url(#ep-rough)" opacity="0.9"/>
              <!-- Lagoon water -->
              <ellipse cx="400" cy="121" rx="178" ry="46" fill="#B5C8DC" stroke="#7898B8" stroke-width="1" opacity="0.85"/>
              <text x="400" y="125" text-anchor="middle" font-size="8" font-style="italic" fill="#3A4A6A" opacity="0.65">World Showcase Lagoon</text>
              <!-- World Showcase label at top arc -->
              <text x="400" y="57" text-anchor="middle" font-size="9" font-style="italic" fill="#3A3860" opacity="0.7" font-weight="bold">World Showcase</text>

              <!-- Country pavilion labels around the lagoon -->
              <text x="153" y="125" text-anchor="middle" font-size="7" font-style="italic" fill="#3A3860" opacity="0.8">Mexico</text>
              <text x="198" y="160" text-anchor="middle" font-size="7" font-style="italic" fill="#3A3860" opacity="0.8" transform="rotate(15,198,160)">Norway</text>
              <text x="260" y="181" text-anchor="middle" font-size="7" font-style="italic" fill="#3A3860" opacity="0.8" transform="rotate(8,260,181)">China</text>
              <text x="322" y="193" text-anchor="middle" font-size="7" font-style="italic" fill="#3A3860" opacity="0.8" transform="rotate(4,322,193)">Germany</text>
              <text x="370" y="197" text-anchor="middle" font-size="7" font-style="italic" fill="#3A3860" opacity="0.8">Italy</text>
              <text x="400" y="199" text-anchor="middle" font-size="7" font-style="italic" fill="#3A3860" opacity="0.8" font-weight="bold">U.S.A.</text>
              <text x="430" y="197" text-anchor="middle" font-size="7" font-style="italic" fill="#3A3860" opacity="0.8">Japan</text>
              <text x="476" y="193" text-anchor="middle" font-size="7" font-style="italic" fill="#3A3860" opacity="0.8" transform="rotate(-4,476,193)">Morocco</text>
              <text x="538" y="181" text-anchor="middle" font-size="7" font-style="italic" fill="#3A3860" opacity="0.8" transform="rotate(-8,538,181)">France</text>
              <text x="600" y="160" text-anchor="middle" font-size="7" font-style="italic" fill="#3A3860" opacity="0.8" transform="rotate(-14,600,160)">U.K.</text>
              <text x="646" y="125" text-anchor="middle" font-size="7" font-style="italic" fill="#3A3860" opacity="0.8">Canada</text>

              <!-- Separator line between World Showcase and Future World -->
              <line x1="148" y1="242" x2="652" y2="242" stroke="#C4A97A" stroke-width="0.75" stroke-dasharray="6 4" opacity="0.35"/>

              <!-- ── SPACESHIP EARTH illustration — dead center between sections ── -->
              <g transform="translate(400,252)" opacity="0.88">
                <line x1="-18" y1="27" x2="-26" y2="46" stroke="#9B7C52" stroke-width="2.5" stroke-linecap="round"/>
                <line x1="0"   y1="29" x2="0"   y2="46" stroke="#9B7C52" stroke-width="2.5" stroke-linecap="round"/>
                <line x1="18"  y1="27" x2="26"  y2="46" stroke="#9B7C52" stroke-width="2.5" stroke-linecap="round"/>
                <circle r="29" fill="#E8E2D5" stroke="#9B7C52" stroke-width="1.5"/>
                <line x1="-29" y1="0" x2="29" y2="0" stroke="#C4A97A" stroke-width="0.6" opacity="0.5"/>
                <line x1="0" y1="-29" x2="0" y2="29" stroke="#C4A97A" stroke-width="0.6" opacity="0.5"/>
                <ellipse rx="29" ry="12" stroke="#C4A97A" stroke-width="0.6" fill="none" opacity="0.5"/>
                <ellipse rx="12" ry="29" stroke="#C4A97A" stroke-width="0.6" fill="none" opacity="0.5"/>
                <line x1="-25" y1="-14" x2="0" y2="29" stroke="#C4A97A" stroke-width="0.5" opacity="0.3"/>
                <line x1="25" y1="-14" x2="0" y2="29" stroke="#C4A97A" stroke-width="0.5" opacity="0.3"/>
              </g>

              <!-- ── FUTURE WORLD LAND AREAS ── -->

              <!-- World Nature — left, sage green -->
              <path d="M 58,320 C 65,299 95,285 132,283 C 170,281 212,293 240,314 C 264,331 272,359 265,384 C 258,409 234,426 202,433 C 168,440 132,432 106,415 C 78,397 62,371 62,346 C 62,335 58,333 58,320 Z" fill="#C8DDB8" stroke="#6A8A48" stroke-width="1.3" filter="url(#ep-rough)" opacity="0.92"/>
              <text x="162" y="344" text-anchor="middle" font-size="10" font-style="italic" fill="#2E5018" opacity="0.88" transform="rotate(-2,162,344)">World Nature</text>

              <!-- World Discovery — right, warm parchment-gold -->
              <path d="M 528,299 C 545,281 580,278 620,278 C 660,281 698,298 718,326 C 736,349 736,380 720,402 C 704,424 674,437 638,441 C 600,444 562,434 540,414 C 518,393 506,366 510,341 C 512,322 515,314 528,299 Z" fill="#E0D5B0" stroke="#8A7832" stroke-width="1.3" filter="url(#ep-rough)" opacity="0.92"/>
              <text x="622" y="348" text-anchor="middle" font-size="10" font-style="italic" fill="#4A3A08" opacity="0.88" transform="rotate(2,622,348)">World Discovery</text>

              <!-- World Celebration — center -->
              <path d="M 312,305 C 325,286 358,278 398,278 C 438,278 470,288 484,307 C 496,322 498,346 488,368 C 478,388 456,404 428,409 C 400,414 370,410 348,397 C 324,382 308,359 308,336 C 308,322 308,320 312,305 Z" fill="#EDE2C0" stroke="#A08838" stroke-width="1.3" filter="url(#ep-rough)" opacity="0.92"/>
