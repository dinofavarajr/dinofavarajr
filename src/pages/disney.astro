        { time: 'Afternoon', icon: '🌤️', items: ["Mickey & Minnie's Runaway Railway — lower waits after 3pm, great ride", "Toy Story Mania! — afternoon lull is the time", "Rise of the Resistance again if Lightning Lane is still available — it holds up on repeat"] },
        { time: 'Evening', icon: '🌙', items: ["Rock 'n' Roller Coaster as the final ride — ends the night exactly right", "Fantasmic! — even send-mode people stop for this"] },
      ],
    },
    animal_kingdom: {
      chill: [
        { time: 'Morning', icon: '🌅', items: ["Kilimanjaro Safaris — animals are most active in the morning, do this first every time", "Gorilla Falls Exploration Trail — slow, beautiful, genuinely excellent", "Maharajah Jungle Trek — same energy, different continent, equally good"] },
        { time: 'Midday', icon: '☀️', items: ["Na'vi River Journey (1★) — it gets 1 star but the animatronic is stunning, only go if under 20 min", "Festival of the Lion King — great AC show, big crowd-pleaser, get there early", "Dinosaur — surprisingly intense for a chill day, heads up"] },
        { time: 'Afternoon', icon: '🌤️', items: ["Kali River Rapids — if it's hot, this is non-negotiable. You will get soaked.", "Conservation Station — quiet, interesting, almost nobody goes here", "Treetop Trails — walk the canopy paths, deeply underrated"] },
        { time: 'Evening', icon: '🌙', items: ["Tree of Life Awakening — the projections at dusk are genuinely beautiful, don't miss it"] },
      ],
      mix: [
        { time: 'Morning', icon: '🌅', items: ["Flight of Passage — get Lightning Lane before anything else, it sells out fast", "Kilimanjaro Safaris — right after Flight while morning animal activity is peak", "Na'vi River Journey (1★) — only worth it under 20 min, otherwise skip"] },
        { time: 'Midday', icon: '☀️', items: ["Expedition Everest — back row for the best experience, always", "Festival of the Lion King — smart midday AC break, surprisingly good show", "Gorilla Falls Exploration Trail — gentle reset after Everest"] },
        { time: 'Afternoon', icon: '🌤️', items: ["Kali River Rapids — afternoon heat makes this mandatory if it's summer", "Dinosaur — often overlooked, genuinely thrilling", "Maharajah Jungle Trek — the tigers alone are worth the walk"] },
        { time: 'Evening', icon: '🌙', items: ["Tree of Life Awakening at dusk — one of the most underrated moments in all of WDW"] },
      ],
      send: [
        { time: 'Rope Drop', icon: '⚡', items: ["Flight of Passage — first ride of the day, no debate, this changes people", "Expedition Everest — back row, right after Flight before lines form", "Kilimanjaro Safaris — morning is when the animals are out, don't skip this"] },
        { time: 'Midday', icon: '☀️', items: ["Kali River Rapids — beat the afternoon heat, you're going to get soaked anyway", "Dinosaur — underrated thrill, better than its reputation", "Na'vi River Journey (1★) — only if walk-on, otherwise the math doesn't work"] },
        { time: 'Afternoon', icon: '🌤️', items: ["Expedition Everest again — it earns the repeat, back row still", "Festival of the Lion King — even send-mode people should see this once", "Gorilla Falls Exploration Trail — the cooldown walk you need after a full send morning"] },
        { time: 'Evening', icon: '🌙', items: ["Flight of Passage one more time if Lightning Lane is available — it holds up on every single ride", "Tree of Life Awakening — end the night here, the projection show is worth staying for"] },
      ],
    },
  };

  document.getElementById('build-day-btn')!.addEventListener('click', () => {
    const who = (document.getElementById('who-coming') as HTMLSelectElement).value;
    const thrill = (document.getElementById('thrill-level') as HTMLSelectElement).value;
    const origin = (document.getElementById('trip-origin') as HTMLSelectElement).value;
    const onlyTrip = (document.getElementById('only-trip') as HTMLSelectElement).value;
    const park = (document.getElementById('which-park') as HTMLSelectElement).value;
    const passholder = (document.getElementById('passholder') as HTMLSelectElement).value;
    const resort = (document.getElementById('resort') as HTMLSelectElement).value;
    const kidsAge = who === 'kids' ? (document.getElementById('kids-age') as HTMLSelectElement).value : '';
    const visitFreq = (document.getElementById('visit-frequency') as HTMLSelectElement).value;
    const tripStart = (document.getElementById('trip-start') as HTMLInputElement).value;
    const tripEnd = (document.getElementById('trip-end') as HTMLInputElement).value;

    const key = `${who}-${thrill}`;
    const rec = recommendations[key];
    if (!rec) return;
    const plan = parkPlans[park]?.[thrill];
    if (!plan) return;

    const weatherTips = getWeatherTips(tripStart, tripEnd);
    const freqTip: string[] = visitFreq === 'first'
      ? ["This is your first time — don't try to do everything. Pick a couple of must-do rides and let the rest surprise you. First trips are about feeling it, not completing it."]
      : visitFreq === '1-5'
      ? ["You've been a few times but you're still building your Disney IQ. Trust the ratings on this page over the stuff you see on random blogs. Some of the best rides have zero hype."]
      : visitFreq === '5-20'
      ? ["You know your way around. Skip the stuff you've already seen enough of and use this trip to finally do the things you always skip. They're probably better than you think."]
      : ["You're a veteran. You don't need a plan — but a plan still helps. Use today to revisit the stuff that earns its repeat and ignore the rest."];
    const contextTips = [...weatherTips, ...freqTip, ...buildContextTips(origin, onlyTrip, passholder, resort, who, kidsAge, park)];
    const contextHTML = contextTips.length > 0 ? `
      <div class="mb-5 p-4 rounded-xl bg-[#EEF0FF] border border-[#A89FF5]/30">
        <p class="text-xs font-medium tracking-widest uppercase text-[#6B5CE7]/70 mb-3">Based on your trip</p>
        <ul class="space-y-2">
          ${contextTips.map(tip => `
            <li class="flex items-start gap-2 text-sm font-light text-dark/70">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[#6B5CE7] flex-shrink-0"></span>
              ${tip}
            </li>
          `).join('')}
        </ul>
      </div>
    ` : '';

    const planHTML = plan.map((block: {icon: string; time: string; items: string[]}) => `
      <div class="mb-5">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-lg">${block.icon}</span>
          <span class="text-xs font-medium tracking-widest uppercase text-[#6B5CE7]/70">${block.time}</span>
        </div>
        <ul class="space-y-1.5">
          ${block.items.map((item: string) => `
            <li class="flex items-start gap-2 text-sm font-light text-dark/70">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[#A89FF5] flex-shrink-0"></span>
              ${item}
            </li>
          `).join('')}
        </ul>
      </div>
    `).join('');

    const resultsEl = document.getElementById('planner-results')!;
    resultsEl.innerHTML = `
      <div class="bg-white rounded-2xl border border-dark/8 p-8 shadow-sm">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-3xl">${rec.emoji}</span>
          <div>
            <h3 class="font-display text-xl text-dark">${rec.vibe}</h3>
            <p class="text-sm font-light text-dark/50 leading-relaxed">${rec.intro}</p>
          </div>
        </div>
        <div class="h-px bg-dark/8 my-5"></div>
        ${contextHTML}
        ${planHTML}
        <div class="mt-4 p-4 rounded-xl bg-[#F5EDD8] border border-[#C4A97A]/30">
          <p class="text-sm font-light text-dark/65 italic">💬 Dino's note: ${rec.note}</p>
        </div>
        <div class="mt-6 p-6 rounded-2xl bg-[#1A1523] border border-[#A89FF5]/20">
          <p class="font-display text-lg text-[#FAF9F5] mb-1">Want this sent to your inbox?</p>
          <p class="text-sm font-light text-[#FAF9F5]/55 mb-4">Drop your email and I'll send you a cleaner version of this plan — plus you can reply directly and I'll give you personal feedback.</p>
          <div id="save-plan-form" class="flex flex-col sm:flex-row gap-3">
            <input
              type="email"
              id="save-email"
              placeholder="your@email.com"
              class="flex-1 px-4 py-2.5 rounded-xl bg-white/10 border border-white/15 text-[#FAF9F5] text-sm placeholder:text-white/30 focus:outline-none focus:border-[#A89FF5]/60"
            />
            <button
              id="save-plan-btn"
              class="flex-shrink-0 px-5 py-2.5 rounded-xl bg-[#A89FF5] text-[#1A1523] text-sm font-medium hover:bg-[#C0B8FF] transition-colors duration-200"
            >
              Save for later →
            </button>
          </div>
          <p id="save-plan-success" class="hidden text-sm text-[#A89FF5] mt-3">Sent to your email! Dino will take a look and let you know what he thinks at his earliest convenience (:</p>
          <p id="save-plan-error" class="hidden text-sm text-red-400 mt-3">Something went wrong. Try again or email me directly.</p>
        </div>
      </div>
    `;

    document.getElementById('save-plan-btn')?.addEventListener('click', async () => {
      const emailInput = document.getElementById('save-email') as HTMLInputElement;
      const btn = document.getElementById('save-plan-btn') as HTMLButtonElement;
      const successMsg = document.getElementById('save-plan-success')!;
      const errorMsg = document.getElementById('save-plan-error')!;
      const emailVal = emailInput?.value?.trim();

      if (!emailVal || !emailVal.includes('@')) {
        emailInput.focus();
        return;
      }

      btn.textContent = 'Sending…';
      btn.disabled = true;

      try {
        const params = new URLSearchParams();
        params.append('email', emailVal);
        params.append('plan', JSON.stringify(plan));
        params.append('vibe', rec.vibe);
        params.append('park', park);
        params.append('thrill', thrill);

        const res = await fetch('/api/save-plan', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: params.toString(),
        });

        const data = await res.json().catch(() => ({}));
        if (res.ok) {
          document.getElementById('save-plan-form')!.classList.add('hidden');
          successMsg.classList.remove('hidden');
        } else {
          throw new Error(data.error || `HTTP ${res.status}`);
        }
      } catch (err) {
        btn.textContent = 'Save for later →';
        btn.disabled = false;
        errorMsg.textContent = `Error: ${err instanceof Error ? err.message : 'unknown'}`;
        errorMsg.classList.remove('hidden');
      }
    });

    resultsEl.classList.remove('hidden');
    resultsEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
