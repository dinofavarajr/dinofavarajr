  function getWeatherTips(startStr: string, endStr: string): string[] {
    if (!startStr) return [];
    // Parse without timezone issues
    const [sy, sm, sd] = startStr.split('-').map(Number);
    const [ey, em, ed] = (endStr || startStr).split('-').map(Number);
    const start = new Date(sy, sm - 1, sd);
    const end = new Date(ey, em - 1, ed);

    const months = new Set<number>();
    const cur = new Date(start);
    while (cur <= end && months.size <= 12) {
      months.add(cur.getMonth());
      cur.setDate(cur.getDate() + 1);
    }

    const tips: string[] = [];
    const m = [...months];

    // Holiday crowds
    const isHolidayWindow =
      (sm === 12 && sd >= 20) || (sm === 1 && sd <= 5) ||
      (em === 12 && ed >= 20) || (em === 1 && ed <= 5);
    if (isHolidayWindow) {
      tips.push("You're visiting during peak holiday season — expect maximum crowds. Rope drop is not optional, it's survival. Lightning Lane for everything you care about.");
    }

    // Summer heat + storms (June–September)
    const isSummer = m.some(mo => [5, 6, 7, 8].includes(mo));
    if (isSummer) {
      tips.push("Florida runs its afternoon thunderstorm script like clockwork in summer — expect storms around 3–4pm. Hit outdoor and thrill rides in the morning, then use the rain window for indoor attractions, food, and AC.");
      tips.push("Heat index will be brutal. Hydrate constantly, wear light clothing, and treat every air-conditioned ride as a bonus break, not just a queue.");
    }

    // Spring (March–May)
    const isSpring = m.some(mo => [2, 3, 4].includes(mo));
    if (isSpring && !isSummer) {
      tips.push("Spring weather in Orlando is genuinely great — warm, manageable humidity, and usually dry. Afternoon pop-up showers are possible in April and May, so a small poncho in your bag doesn't hurt.");
    }

    // Fall sweet spot (October–November)
    const isFall = m.some(mo => [9, 10].includes(mo));
    if (isFall) {
      tips.push("October and November are arguably the best time to visit — crowds thin out, temps drop into the 70s, and the Halloween and holiday overlays are running. You picked well.");
    }

    // Winter (December–February, non-holiday)
    const isWinter = m.some(mo => [11, 0, 1].includes(mo));
    if (isWinter && !isHolidayWindow) {
      tips.push("Florida winters can catch people off guard — mornings can dip into the 50s. Pack a light layer for early park entry and evening fireworks, then shed it by midday when it warms up.");
    }

    return tips;
  }

  function buildContextTips(origin: string, onlyTrip: string, passholder: string, resort: string, who: string, kidsAge: string, park: string): string[] {
    const tips: string[] = [];

    if (passholder === 'yes') {
      tips.push("You're a passholder — don't grind through everything. Save the stuff that can wait for your next visit and focus on what actually hits today.");
    } else if (origin === 'out-of-town' && onlyTrip === 'yes') {
      tips.push("You traveled here and this is your one shot this year. Don't leave anything on the table. Lightning Lane the rides you care about most before they sell out.");
    } else if (onlyTrip === 'no') {
      tips.push("You're coming back, so take the pressure off. Miss something today and save it for next time. That's a feature, not a bug.");
    }

    if (resort === 'on-property') {
      tips.push("You have Early Theme Park Entry — 30 minutes before official open. Use it on your single most-wanted ride before the crowds catch up.");
    } else if (resort === 'off-property' || resort === 'day-trip') {
      tips.push("No early entry, so be at the gate at least 15 minutes before official park open. The first 90 minutes are everything.");
    }

    if (who === 'kids') {
      if (kidsAge === 'toddlers') {
        tips.push("Toddlers will hit a wall after lunch — that's not a maybe, that's a guarantee. Schedule a hotel break or quiet rest window. Fighting it costs you the whole afternoon.");
      } else if (kidsAge === 'tweens') {
        const llRide = park === 'magic_kingdom' ? 'TRON and Seven Dwarfs Mine Train' : park === 'hollywood_studios' ? 'Rise of the Resistance and Slinky Dog Dash' : park === 'animal_kingdom' ? 'Flight of Passage' : 'Guardians of the Galaxy and Test Track';
        tips.push(`Tweens want the big rides. Get Lightning Lane for ${llRide} first thing — those sell out fast and the standby waits are brutal.`);
      } else if (kidsAge === 'mixed') {
        tips.push("Mixed ages means a split strategy: one adult per group in different queues, then regroup. Pre-plan your meet-up spots so nobody's standing around waiting.");
      } else if (kidsAge === 'young') {
        tips.push("Kids 5–8 have more stamina than toddlers but still need a midday reset. Keep the afternoon schedule lighter and let them pick one ride to ride twice — it matters more to them than you think.");
      }
    }

    if (origin === 'local' && passholder === 'no') {
      tips.push("Local day tripper energy: you can leave whenever it stops being fun. That's a superpower. Use it.");
    }

    return tips;
  }

