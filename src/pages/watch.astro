---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import KitForm from '../components/KitForm.astro';
---

<Layout
  title="Watch | Dino Favara Jr."
  description="Never miss a video. Get my newest video sent directly to your inbox as soon as it's posted."
>
  <Nav />

  <main>
    <section class="relative overflow-hidden bg-dark min-h-[calc(100vh-72px)] flex items-center">
      <!-- Ambient blobs -->
      <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <div class="absolute -top-32 -left-32 w-[500px] h-[500px] rounded-full bg-primary/30 blur-[100px]"></div>
        <div class="absolute top-40 -right-20 w-[400px] h-[400px] rounded-full bg-periwinkle/20 blur-[90px]"></div>
        <div class="absolute bottom-0 left-1/3 w-[300px] h-[300px] rounded-full bg-mint/10 blur-[80px]"></div>
      </div>

      <div class="relative z-10 max-w-2xl mx-auto px-6 py-24 text-center flex flex-col items-center gap-8">
        <span class="text-6xl select-none" aria-hidden="true">🎬</span>

        <div class="flex flex-col gap-4">
          <p class="text-sm font-medium tracking-widest uppercase text-mint/80">Never miss a video</p>
          <h1 class="font-display text-[clamp(2.4rem,6vw,4rem)] leading-[1.06] tracking-tight text-off-white">
            Get my newest video sent directly to your inbox as soon as it's posted
          </h1>
        </div>

        <p class="text-[1.05rem] font-light text-off-white/60 leading-relaxed max-w-sm">
          Drop your email and I'll send you each new video the moment it goes live — no algorithms, no missing out.
        </p>

        <div class="w-full max-w-md">
          <KitForm
            formId="9211740"
            instanceId="watch-signup-form"
            buttonText="Send me videos →"
            buttonStyle="mint"
            inputDark={true}
            redirectUrl="https://youtube.com/@dinofavarajr"
          />
        </div>

        <a
          href="https://youtube.com/@dinofavarajr"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium text-off-white/40 hover:text-off-white/70 transition-colors"
        >
          Just take me to YouTube →
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
